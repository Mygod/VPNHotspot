  <string name="wifi_mac_randomization_non_persistent">Nepastāvīga nejaušošana</string>
  <string name="wifi_mac_randomization_non_persistent_help">Ģenerē nejaušu AP MAC adresi katru reizi, kad AP tiek atkārtoti iespējots.</string>
