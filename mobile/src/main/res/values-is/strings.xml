  <string name="settings_service_upstream_help">Regex fyrir aðal uppstreymisviðmót sem er notað til að endurbeina niðurstreymisumferð. VPN Hotspot sjálft verður að fá að nota það VPN til að virka. Notaðu &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; eða annan ógildan regex til að bæla tjóðrun í gegnum VPN.</string>
  <string name="settings_upstream_fallback_help">Vara-uppstreymi er notað þegar VPN skilur nokkrar leiðir eftir á sjálfgefna netinu. Notaðu &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; eða annan ógildan regex til að banna varaleið.</string>
  <string name="settings_service_masquerade_none_summary">Ekki endurskrifa upprunavistföng eða gáttir niðurstreymis. Þetta getur virkað betur með gervi-VPN-um eins og auglýsingalokum eða socksifierum, en ætti ekki að nota með raunverulegum VPN-um.</string>
  <string name="settings_service_masquerade_simple_summary">Endurskrifa upprunavistföng og gáttir niðurstreymis í leiðarreglum appsins.</string>
  <string name="settings_service_masquerade_netd_summary">Láta Android &lt;tt&gt;netd&lt;/tt&gt; sjá um masquerade. Android getur bætt við kerfisviðbótum eins og &lt;tt&gt;FTP&lt;/tt&gt;-meðhöndlun og tethering-teljurum, en þetta hentar illa þegar á að fela tethering-virkni fyrir símafyrirtækinu.</string>
  <string name="settings_service_ipv6_mode_system_summary">Lætur IPv6-meðhöndlun vera hjá leiðarstillingu kerfisins.</string>
  <string name="settings_service_ipv6_mode_block_summary">Kemur í veg fyrir IPv6-leka á niðurstreymisviðmótum.</string>
  <string name="settings_service_ipv6_mode_nat_summary">Úthlutar determinísku app-eignuðu ULA &lt;tt&gt;/64&lt;/tt&gt; og proxyar niðurstreymis IPv6 &lt;tt&gt;TCP&lt;/tt&gt;/&lt;tt&gt;UDP&lt;/tt&gt; ásamt best-effort &lt;tt&gt;ICMPv6&lt;/tt&gt; í gegnum root-daemon. Þetta er notendarýmisvinna, ekki fullt packet NAT, og framsendir ekki önnur IPv6 next-header samskiptareglur.</string>
  <string name="settings_service_auto_start">Ræsa þjónustur sjálfkrafa</string>
  <string name="settings_service_auto_start_summary">Endurheimta þjónustur ef þær voru í gangi áður en tækið endurræstist eða appið var uppfært.</string>
  <string name="settings_service_repeater_safe_mode">Örugg stilling endurvarpa</string>
  <string name="settings_service_repeater_safe_mode_summary">Gerir engar breytingar á kerfisstillingum en virkar hugsanlega ekki með stuttum netnöfnum. Óörugg stilling virkar hugsanlega ekki í tækinu þínu og getur gert það tímabundið ónothæft á endurheimtanlegan hátt.</string>
  <string name="settings_service_repeater_safe_mode_warning">Stutt netnöfn gætu krafist þess að slökkva á öruggri stillingu.</string>
  <string name="settings_service_temp_hotspot_use_system">Nota kerfisstillingu fyrir tímabundinn heitan reit</string>
  <string name="settings_service_temp_hotspot_use_system_summary">Mun rekast á önnur öpp sem nota staðbundinn heitan reit eingöngu. Notar líka meiri tilföng í bakgrunni nema það sé sett upp sem kerfisapp.</string>
  <string name="settings_service_temp_hotspot_use_system_summary_api30">Mun rekast á önnur öpp sem nota staðbundinn heitan reit eingöngu. Notar líka meiri tilföng í bakgrunni nema það sé sett upp sem kerfisapp. Virkar líklegast á Android 12 eða nýrra.</string>
  <string name="settings_service_wifi_lock">Halda Wi‑Fi vakandi</string>
  <string name="settings_service_wifi_lock_none">Sjálfgildi kerfis</string>
  <string name="settings_service_wifi_lock_high_perf_v29">Slökkva á orkusparnaði</string>
  <string name="settings_service_wifi_lock_low_latency">Lág biðtímastilling</string>
  <string name="settings_service_wifi_lock_none_summary">Nota sjálfgefna Wi‑Fi orkuhegðun kerfisins til að spara rafhlöðu.</string>
  <string name="settings_service_wifi_lock_high_perf_v29_summary">Dregur úr pakkaseinkun í tilvikum eins og símtölum eftir að slökkt er á skjánum. Krefst vélbúnaðarstuðnings. Í Android 14 og nýrra er þessari úreltu stillingu skipt út fyrir lága seinkunarstillingu.</string>
  <string name="settings_service_wifi_lock_low_latency_summary">Bestar notkun sem er viðkvæm fyrir seinkun, eins og leiki eða sýndarveruleika. Getur minnkað rafhlöðuendingu, afköst, tíðni Wi‑Fi skönnunar, reiki-gæði og staðsetningarnákvæmni. Krefst vélbúnaðarstuðnings og þess að þetta app sé í forgrunni með kveiktan skjá.</string>
  <string name="settings_service_upstream">Uppstreymisnetviðmót</string>
  <string name="settings_service_upstream_auto">Greina kerfis-VPN sjálfkrafa</string>
  <string name="settings_upstream_fallback">Vara-uppstreymisviðmót</string>
  <string name="settings_upstream_fallback_auto">Greina sjálfgefið net kerfis sjálfkrafa</string>
  <string name="settings_upstream_current_summary">%1$s (núverandi: %2$s)</string>
  <string name="settings_service_clean">Hreinsa/beita leiðarreglum aftur</string>
  <string name="settings_service_clean_summary">Uppfæra breyttar stillingar í núverandi virkar þjónustur. Getur einnig lagað sjaldgæf kapphlaupsskilyrði.</string>
  <string name="settings_system_tether_offload">Vélbúnaðarhröðun fyrir tjóðrun</string>
  <string name="settings_system_tether_offload_summary">Flýtileið í þróunarvalkosti kerfisins. Oft þarf að slökkva á þessu fyrir VPN-tethering yfir kerfis-tethering, en það getur minnkað rafhlöðuendingu meðan tethering er virkt.</string>
