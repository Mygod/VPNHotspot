  <string name="wifi_hotspot_ap_band_title">Tíðnisvið</string>
  <string name="wifi_hotspot_ap_channel_band_title">AP-rás/tíðnisvið</string>
  <string name="wifi_hotspot_ap_channel_band_help">Óstutt tíðnisvið/rás getur valdið því að heitur reitur ræsist ekki.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Samhliða AP-rás/tíðnisvið</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">Bætir við annarri AP-tilviki þegar bridged AP concurrency er studd. Óstuddar band/rás samsetningar geta mistekist þegar heiti reiturinn er ræstur.</string>
  <string name="wifi_band_optimization">Virkja bestun tíðnisviðs</string>
  <string name="wifi_band_optimization_help">Leyfir Android að besta tíðnisviðsstillingar, til dæmis að bæta við 2.4 GHz-sviðinu vegna samnýtingar eða landskóðatakmarkana.</string>
  <string name="wifi_ap_choose_disabled">Óvirkt</string>
  <string name="wifi_ap_choose_G">%s GHz tíðnisvið</string>
  <string name="wifi_hotspot_acs_channel_2g">Leyfðar 2.4 GHz ACS-rásir</string>
  <string name="wifi_hotspot_acs_channel_5g">Leyfðar 5 GHz ACS-rásir</string>
  <string name="wifi_hotspot_acs_channel_6g">Leyfðar 6 GHz ACS-rásir</string>
  <string name="wifi_hotspot_acs_channel_help">Rásanúmer sem eru leyfð fyrir Automatic Channel Selection á þessu bandi. Sláðu inn rásir eða svið aðskilin með kommum, t.d. &lt;tt&gt;1,6,11&lt;/tt&gt; eða &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Skildu eftir autt til að leyfa allar rásir á bandinu. Krefst ACS offload stuðnings; annars hunsar Android þessa stillingu.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Hámarksbandbreidd rásar</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Takmarkar rásarbandbreidd Soft AP. Auto leyfir Android að nota mestu bandbreidd sem tækið getur náð.</string>
  <string name="wifi_channel_width_auto">Sjálfvirkt</string>
  <string name="wifi_channel_width_invalid">Ógilt</string>
  <string name="wifi_hotspot_access_control_title">Aðgangsstýring</string>
  <string name="wifi_hotspot_ap_advanced_title">Ítarlegri valkostir</string>
  <string name="wifi_advanced_mac_address_title">MAC-vistfang</string>
  <string name="wifi_mac_address_persistent_randomization">Viðvarandi slembun: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Óviðvarandi slembun</string>
  <string name="wifi_mac_address_help">Stilltu BSSID og MAC-slembun fyrir AP. Android hafnar BSSID sem eru aðeins núll, multicast eða broadcast. Skýrt BSSID er aðeins notað þegar slökkt er á MAC-slembun.</string>
  <string name="wifi_p2p_mac_address_help">Stilltu vistfang P2P-tækis sem endurvarpinn notar. Skildu eftir autt til að Android velji vistfangið.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Varanlegt slembið MAC-vistfang</string>
  <string name="wifi_hidden_network">Falið net</string>
  <string name="wifi_hidden_network_help">Ekki senda út SSID</string>
  <string name="wifi_max_clients">Hámarksfjöldi biðlara</string>
  <string name="wifi_max_clients_help">Hámarksfjöldi biðlara sem geta tengst AP. Ef tómt notar Android takmörk tækis eða símafyrirtækis; biðlurum yfir mörkum er hafnað.</string>
  <string name="wifi_blocked_list">Listi yfir lokaða biðlara</string>
  <string name="wifi_blocked_list_help">MAC-vistföng sem geta ekki tengst Soft AP. Krefst stuðnings við þvingaða aftengingu biðlara; annars getur heitur reitur mistekist að ræsa með villu um óstudda stillingu.</string>
  <string name="wifi_client_user_control">Notendastýring á tengingu biðlara</string>
  <string name="wifi_client_user_control_help">Slökkt: allir biðlarar utan bannlista geta tengst með réttum auðkennum þar til heiti reiturinn fyllist; leyfislisti er hunsaður. Kveikt: Android notar leyfis- og bannlista til að samþykkja, hafna eða biðja um samþykki. Krefst þvingaðrar aftengingar biðlara.</string>
  <string name="wifi_allowed_list">Listi yfir leyfða biðlara</string>
  <string name="wifi_client_lists_overlap_error">MAC-vistfang er á báðum biðlaralistum</string>
  <string name="wifi_mac_randomization_none">Engin slembun</string>
  <string name="wifi_mac_randomization_none_help">Nota verksmiðju- eða sérstaklega stillt AP MAC-vistfang.</string>
  <string name="wifi_mac_randomization_persistent">Viðvarandi slembun</string>
  <string name="wifi_mac_randomization_persistent_help">Býr til slembið AP MAC-vistfang sem er varðveitt fyrir hvert SSID meðan SSID er óbreytt.</string>
  <string name="wifi_mac_randomization_non_persistent">Óviðvarandi slembun</string>
  <string name="wifi_mac_randomization_non_persistent_help">Býr til slembið AP MAC-vistfang í hvert skipti sem AP er virkjað aftur.</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown">Tækifærissinnuð lokun í brúarstillingu</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown_help">Í bridged AP stillingu getur Android slökkt á aðgerðalausu AP-tilviki eftir bridged timeout: %s</string>
  <string name="wifi_hotspot_timeout_bridged">Aðgerðaleysi fyrir brúartilvik</string>
  <string name="wifi_hotspot_timeout_bridged_help">Stilltu hve lengi aðgerðalaust bridged AP-tilvik bíður fyrir tækifærisslokknun. Ef bæði tilvik eru aðgerðalaus slekkur Android á tilvikinu með hærri tíðni. Heildartímalok heita reitsins gilda áfram sérstaklega.&lt;br&gt;&lt;br&gt;Sjálfgefið: %s</string>
