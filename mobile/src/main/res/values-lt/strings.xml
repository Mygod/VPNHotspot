  <string name="settings_service_temp_hotspot_use_system_summary">Konfliktuos su kitomis programomis, naudojančiomis tik vietinį hotspot. Taip pat fone naudoja daugiau išteklių, nebent įdiegta kaip sistemos programa.</string>
  <string name="settings_service_temp_hotspot_use_system_summary_api30">Konfliktuos su kitomis programomis, naudojančiomis tik vietinį hotspot. Taip pat fone naudoja daugiau išteklių, nebent įdiegta kaip sistemos programa. Greičiausiai veikia Android 12 arba naujesnėje versijoje.</string>
  <string name="settings_service_wifi_lock">Laikyti Wi‑Fi aktyvų</string>
