  <string name="wifi_hidden_network_help">Ne emitiraj SSID</string>
  <string name="wifi_max_clients">Maksimalan broj klijenata</string>
  <string name="wifi_max_clients_help">Maksimalan broj klijenata koji se mogu povezati s AP-om. Ako je prazno, Android koristi ograničenje uređaja ili operatera; klijenti iznad ograničenja se odbijaju.</string>
  <string name="wifi_blocked_list">Popis blokiranih klijenata</string>
  <string name="wifi_blocked_list_help">MAC adrese koje se ne mogu povezati sa Soft AP-om. Zahtijeva podršku za prisilno odspajanje klijenta; u suprotnom se hotspot može ne pokrenuti uz pogrešku nepodržane konfiguracije.</string>
  <string name="wifi_client_user_control">Korisnička kontrola povezivanja klijenata</string>
  <string name="wifi_client_user_control_help">Isključeno: svaki klijent izvan popisa blokiranih može se povezati ispravnim podacima dok se hotspot ne popuni; popis dopuštenih se zanemaruje. Uključeno: Android koristi popise dopuštenih i blokiranih za prihvaćanje, odbijanje ili traženje odobrenja. Zahtijeva prisilno odspajanje klijenta.</string>
