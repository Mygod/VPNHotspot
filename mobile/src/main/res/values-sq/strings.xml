  <string name="wifi_mac_address_persistent_randomization">Rastësim i vazhdueshëm: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Rastësim jo i vazhdueshëm</string>
  <string name="wifi_mac_address_help">Konfiguroni BSSID dhe rastësimin MAC për AP. Android refuzon BSSID me vetëm zero, multicast dhe broadcast. Një BSSID i qartë përdoret vetëm kur rastësimi MAC është i fikur.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Adresë MAC e rastësishme e qëndrueshme</string>
  <string name="wifi_hidden_network">Rrjet i fshehur</string>
  <string name="wifi_hidden_network_help">Mos transmeto SSID-në</string>
  <string name="wifi_max_clients">Numri maksimal i klientëve</string>
  <string name="wifi_max_clients_help">Numri maksimal i klientëve që mund të lidhen me AP. Nëse lihet bosh, Android përdor kufirin e pajisjes ose operatorit; klientët mbi kufi refuzohen.</string>
  <string name="wifi_blocked_list">Lista e klientëve të bllokuar</string>
  <string name="wifi_blocked_list_help">Adresa MAC që nuk mund të lidhen me Soft AP. Kërkon mbështetje për shkëputje të detyruar të klientit; përndryshe hotspot-i mund të dështojë të nisë me gabim konfigurimi të pambështetur.</string>
  <string name="wifi_client_user_control">Kontrolli i përdoruesit mbi lidhjen e klientëve</string>
  <string name="wifi_client_user_control_help">Fikur: çdo klient jashtë listës së bllokuar mund të lidhet me kredencialet e sakta derisa hotspot-i të mbushet; lista e lejuar shpërfillet. Ndezur: Android përdor listat e lejuara dhe të bllokuara për pranim, refuzim ose kërkesë miratimi. Kërkon shkëputje të detyruar të klientit.</string>
  <string name="wifi_allowed_list">Lista e klientëve të lejuar</string>
  <string name="wifi_client_lists_overlap_error">Një adresë MAC gjendet në të dyja listat e klientëve</string>
  <string name="wifi_mac_randomization_none">Pa rastësim</string>
  <string name="wifi_mac_randomization_none_help">Përdor adresën MAC AP të fabrikës ose të konfiguruar shprehimisht.</string>
  <string name="wifi_mac_randomization_persistent">Rastësim i vazhdueshëm</string>
  <string name="wifi_mac_randomization_persistent_help">Krijon një adresë MAC AP të rastësishme që ruhet për SSID për sa kohë SSID mbetet i njëjtë.</string>
  <string name="wifi_mac_randomization_non_persistent">Rastësim jo i vazhdueshëm</string>
  <string name="wifi_mac_randomization_non_persistent_help">Krijon një adresë MAC AP të rastësishme sa herë që AP aktivizohet përsëri.</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown">Fikje oportuniste në modalitetin urë</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown_help">Në bridged AP mode, Android mund të fikë një instancë AP joaktive pas bridged timeout: %s</string>
  <string name="wifi_hotspot_timeout_bridged">Afati i pasivitetit për instancë urë</string>
  <string name="wifi_hotspot_timeout_bridged_help">Konfiguro sa kohë pret një instancë bridged AP joaktive para opportunistic shutdown. Nëse të dyja instancat janë joaktive, Android fik instancën me frekuencë më të lartë. Timeout i përgjithshëm i hotspot vazhdon të zbatohet veçmas.&lt;br&gt;&lt;br&gt;Parazgjedhje: %s</string>
