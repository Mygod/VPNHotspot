  <string name="wifi_hotspot_ap_channel_band_help">Brezi/kanali i pambështetur mund ta bëjë hotspot-in të mos niset.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Kanali/brezi AP i njëkohshëm</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">Shton një instancë të dytë AP kur mbështetet bridged AP concurrency. Kombinimet band/channel të pambështetura mund të dështojnë kur hotspot niset.</string>
  <string name="wifi_band_optimization">Aktivizo optimizimin e brezit</string>
  <string name="wifi_band_optimization_help">Lejon Android të optimizojë cilësimet e brezit, si shtimi i brezit 2.4 GHz për bashkëjetesë ose kufizime të kodit të vendit.</string>
  <string name="wifi_ap_choose_disabled">Të çaktivizuara</string>
  <string name="wifi_ap_choose_G">Brezi %s GHz</string>
  <string name="wifi_hotspot_acs_channel_2g">Kanalet ACS 2.4 GHz të lejuara</string>
  <string name="wifi_hotspot_acs_channel_5g">Kanalet ACS 5 GHz të lejuara</string>
  <string name="wifi_hotspot_acs_channel_6g">Kanalet ACS 6 GHz të lejuara</string>
  <string name="wifi_hotspot_acs_channel_help">Numrat e kanaleve të lejuara për Automatic Channel Selection në këtë band. Fut kanale ose intervale të ndara me presje, si &lt;tt&gt;1,6,11&lt;/tt&gt; ose &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Lëre bosh për të lejuar të gjitha kanalet në band. Kërkon mbështetje ACS offload; përndryshe Android e shpërfill këtë cilësim.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Gjerësia maksimale e kanalit</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Kufizon gjerësinë e kanalit Soft AP. Auto lejon Android të përdorë gjerësinë maksimale të arritshme në pajisje.</string>
  <string name="wifi_channel_width_auto">Automatike</string>
  <string name="wifi_channel_width_invalid">I pavlefshëm</string>
  <string name="wifi_hotspot_access_control_title">Kontrolli i qasjes</string>
  <string name="wifi_hotspot_ap_advanced_title">Opsionet e përparuara</string>
