  <string name="settings_service_upstream_help">Regex-i i ndërfaqes kryesore upstream që përdoret për të rirutuar trafikun downstream. Vetë VPN Hotspot duhet të lejohet ta përdorë atë VPN që të funksionojë. Përdor &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; ose një regex tjetër të pavlefshëm për të shtypur tetheringun përmes VPN.</string>
  <string name="settings_upstream_fallback_help">Upstream rezervë përdoret kur një VPN lë disa rrugë në rrjetin e parazgjedhur. Përdor &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; ose një regex tjetër të pavlefshëm për të ndaluar rezervën.</string>
  <string name="settings_service_masquerade_none_summary">Mos i rishkruaj adresat burimore ose portat downstream. Kjo mund të funksionojë më mirë me VPN të rreme si bllokues reklamash ose socksifier, por nuk duhet përdorur me VPN reale.</string>
  <string name="settings_service_masquerade_simple_summary">Rishkruaj adresat burimore dhe portat downstream në rregullat e rrugëzimit të aplikacionit.</string>
  <string name="settings_service_masquerade_netd_summary">Kërkoji Android &lt;tt&gt;netd&lt;/tt&gt; të trajtojë masquerade. Android mund të shtojë shtesa platforme si trajtimi i &lt;tt&gt;FTP&lt;/tt&gt; dhe numërues tethering, por kjo nuk përshtatet kur aktiviteti tethering duhet fshehur nga operatori.</string>
  <string name="settings_service_ipv6_mode_system_summary">Lë trajtimin e IPv6 te konfigurimi i rutimit të platformës.</string>
  <string name="settings_service_ipv6_mode_block_summary">Parandalon rrjedhjet IPv6 në ndërfaqet downstream.</string>
  <string name="settings_service_ipv6_mode_nat_summary">Cakton një ULA &lt;tt&gt;/64&lt;/tt&gt; deterministike në pronësi të aplikacionit dhe proxy IPv6 downstream &lt;tt&gt;TCP&lt;/tt&gt;/&lt;tt&gt;UDP&lt;/tt&gt; plus best-effort &lt;tt&gt;ICMPv6&lt;/tt&gt; përmes root daemon. Kjo është punë në hapësirë përdoruesi, jo packet NAT i plotë, dhe nuk përcjell protokolle të tjera IPv6 next-header.</string>
  <string name="settings_service_auto_start">Nis shërbimet automatikisht</string>
  <string name="settings_service_auto_start_summary">Rikthe shërbimet nëse po ekzekutoheshin para rindezjes së pajisjes ose përditësimit të aplikacionit.</string>
  <string name="settings_service_temp_hotspot_use_system">Përdor konfigurimin e sistemit për hotspot të përkohshëm</string>
  <string name="settings_service_temp_hotspot_use_system_summary">Do të konfliktohet me aplikacione të tjera që përdorin hotspot vetëm lokal. Përdor edhe më shumë burime në sfond nëse nuk është instaluar si aplikacion sistemi.</string>
  <string name="settings_service_temp_hotspot_use_system_summary_api30">Do të konfliktohet me aplikacione të tjera që përdorin hotspot vetëm lokal. Përdor edhe më shumë burime në sfond nëse nuk është instaluar si aplikacion sistemi. Ka shumë gjasa të funksionojë në Android 12 ose më të ri.</string>
  <string name="settings_service_wifi_lock">Mbaj Wi‑Fi aktiv</string>
  <string name="settings_service_wifi_lock_none">Parazgjedhja e sistemit</string>
  <string name="settings_service_wifi_lock_high_perf_v29">Çaktivizo kursimin e energjisë</string>
  <string name="settings_service_wifi_lock_low_latency">Modalitet me vonesë të ulët</string>
  <string name="settings_service_wifi_lock_none_summary">Përdor sjelljen e parazgjedhur të energjisë Wi‑Fi të sistemit për të kursyer baterinë.</string>
  <string name="settings_service_wifi_lock_high_perf_v29_summary">Ul vonesën e paketave për raste si thirrjet zanore pasi ekrani fiket. Kërkon mbështetje harduerike. Në Android 14 dhe më të ri, ky modalitet i vjetruar zëvendësohet me modalitetin me vonesë të ulët.</string>
  <string name="settings_service_wifi_lock_low_latency_summary">Optimizon përdorime të ndjeshme ndaj vonesës, si lojërat ose realiteti virtual. Mund të ulë jetëgjatësinë e baterisë, throughput, frekuencën e skanimit Wi‑Fi, cilësinë e roaming dhe saktësinë e vendndodhjes. Kërkon mbështetje harduerike dhe këtë aplikacion në plan të parë me ekranin ndezur.</string>
  <string name="settings_service_upstream">Ndërfaqe rrjeti upstream</string>
  <string name="settings_service_upstream_auto">Zbulo automatikisht VPN-in e sistemit</string>
  <string name="settings_upstream_fallback">Ndërfaqe upstream rezervë</string>
  <string name="settings_upstream_fallback_auto">Zbulo automatikisht rrjetin e parazgjedhur të sistemit</string>
  <string name="settings_upstream_current_summary">%1$s (aktuale: %2$s)</string>
  <string name="settings_service_clean">Pastro/riapliko rregullat e rrugëzimit</string>
  <string name="settings_service_clean_summary">Zbato cilësimet e ndryshuara te shërbimet aktive aktuale. Mund të rregullojë edhe race condition të rralla.</string>
  <string name="settings_system_tether_offload">Përshpejtimi i harduerit për ndarjen e lidhjes (internet)</string>
  <string name="settings_system_tether_offload_summary">Shkurtore te opsionet e zhvilluesit të sistemit. Fikja e kësaj shpesh nevojitet për VPN tethering përmes tethering të sistemit, por mund të ulë jetëgjatësinë e baterisë ndërsa tethering është aktiv.</string>
