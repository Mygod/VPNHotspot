  <string name="settings_service_upstream_help">Regex hlavného nadradeného rozhrania používaný na presmerovanie podradeného prenosu. Samotný VPN Hotspot musí mať povolené používať túto VPN, aby fungoval. Použite &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; alebo iný neplatný regex na potlačenie zdieľania cez VPN.</string>
  <string name="settings_upstream_fallback_help">Záložný nadradený upstream sa používa, keď VPN ponechá niektoré trasy v predvolenej sieti. Použite &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; alebo iný neplatný regex na zakázanie zálohy.</string>
  <string name="settings_service_masquerade_none_summary">Neprepisovať zdrojové adresy ani porty downstream prevádzky. Môže to lepšie fungovať s nepravými VPN, napríklad blokovačmi reklám alebo socksifiermi, ale nemalo by sa to používať so skutočnými VPN.</string>
  <string name="settings_service_masquerade_simple_summary">Prepísať zdrojové adresy a porty downstream prevádzky v smerovacích pravidlách aplikácie.</string>
  <string name="settings_service_masquerade_netd_summary">Požiadať Android &lt;tt&gt;netd&lt;/tt&gt; o spracovanie masquerade. Android môže pridať platformové doplnky, napríklad spracovanie &lt;tt&gt;FTP&lt;/tt&gt; a počítadlá tetheringu, ale nehodí sa to, keď má byť aktivita tetheringu skrytá pred operátorom.</string>
  <string name="settings_service_ipv6_mode_system_summary">Ponechá spracovanie IPv6 na smerovacie nastavenie platformy.</string>
  <string name="settings_service_ipv6_mode_block_summary">Zabráni únikom IPv6 na downstream rozhraniach.</string>
  <string name="settings_service_ipv6_mode_nat_summary">Priradí deterministickú ULA &lt;tt&gt;/64&lt;/tt&gt; vlastnenú aplikáciou a cez root daemon proxyuje downstream IPv6 &lt;tt&gt;TCP&lt;/tt&gt;/&lt;tt&gt;UDP&lt;/tt&gt; plus best-effort &lt;tt&gt;ICMPv6&lt;/tt&gt;. Je to práca v používateľskom priestore, nie plný paketový NAT, a nepreposiela iné protokoly IPv6 next-header.</string>
  <string name="settings_service_auto_start">Automaticky spúšťať služby</string>
  <string name="settings_service_auto_start_summary">Obnoviť služby, ak bežali pred reštartom zariadenia alebo aktualizáciou aplikácie.</string>
  <string name="settings_service_temp_hotspot_use_system">Použiť systémovú konfiguráciu pre dočasný hotspot</string>
  <string name="settings_service_temp_hotspot_use_system_summary">Bude v konflikte s inými aplikáciami používajúcimi iba lokálny hotspot. Taktiež používa viac zdrojov na pozadí, ak nie je nainštalovaná ako systémová aplikácia.</string>
  <string name="settings_service_temp_hotspot_use_system_summary_api30">Bude v konflikte s inými aplikáciami používajúcimi iba lokálny hotspot. Taktiež používa viac zdrojov na pozadí, ak nie je nainštalovaná ako systémová aplikácia. Najpravdepodobnejšie funguje na Androide 12 alebo novšom.</string>
  <string name="settings_service_wifi_lock">Udržiavať Wi‑Fi aktívne</string>
  <string name="settings_service_wifi_lock_none">Predvolené systémom</string>
  <string name="settings_service_wifi_lock_high_perf_v29">Vypnúť úsporu energie</string>
  <string name="settings_service_wifi_lock_low_latency">Režim nízkej latencie</string>
  <string name="settings_service_wifi_lock_none_summary">Použiť predvolené systémové správanie napájania Wi‑Fi na šetrenie batérie.</string>
  <string name="settings_service_wifi_lock_high_perf_v29_summary">Znižuje latenciu paketov v prípadoch ako hlasové hovory po vypnutí obrazovky. Vyžaduje hardvérovú podporu. V Androide 14 a novšom je tento zastaraný režim nahradený režimom nízkej latencie.</string>
  <string name="settings_service_wifi_lock_low_latency_summary">Optimalizuje použitia citlivé na latenciu, napríklad hry alebo virtuálnu realitu. Môže znížiť výdrž batérie, priepustnosť, frekvenciu skenovania Wi‑Fi, kvalitu roamingu a presnosť polohy. Vyžaduje hardvérovú podporu a spustenie tejto aplikácie v popredí so zapnutou obrazovkou.</string>
  <string name="settings_service_upstream">Nadradené sieťové rozhranie</string>
  <string name="settings_service_upstream_auto">Automaticky zistiť systémovú VPN</string>
  <string name="settings_upstream_fallback">Záložné nadradené rozhranie</string>
  <string name="settings_upstream_fallback_auto">Automaticky zistiť predvolenú sieť systému</string>
  <string name="settings_upstream_current_summary">%1$s (aktuálne: %2$s)</string>
  <string name="settings_service_clean">Vyčistiť/znova použiť pravidlá smerovania</string>
  <string name="settings_service_clean_summary">Použiť zmenené nastavenia na aktuálne aktívne služby. Môže tiež opraviť zriedkavé súbehové chyby.</string>
  <string name="settings_system_tether_offload">Hardvérová akcelerácia tetheringu</string>
  <string name="settings_system_tether_offload_summary">Skratka do systémových možností pre vývojárov. Vypnutie je často potrebné pre VPN tethering cez systémový tethering, ale môže znížiť výdrž batérie, kým je tethering aktívny.</string>
