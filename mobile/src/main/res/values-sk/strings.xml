  <string name="wifi_hotspot_ap_band_title">Pásmo prístupového bodu</string>
  <string name="wifi_hotspot_ap_channel_band_title">Kanál/pásmo AP</string>
  <string name="wifi_hotspot_ap_channel_band_help">Nepodporované pásmo/kanál môže spôsobiť zlyhanie spustenia hotspotu.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Súbežný kanál/pásmo AP</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">Pridá druhú inštanciu AP, keď je podporovaná súbežnosť bridged AP. Nepodporované kombinácie pásma/kanála môžu zlyhať pri spustení hotspotu.</string>
  <string name="wifi_band_optimization">Povoliť optimalizáciu pásma</string>
  <string name="wifi_band_optimization_help">Umožní Androidu optimalizovať nastavenia pásma, napríklad pridať pásmo 2.4 GHz kvôli koexistencii alebo obmedzeniam kódu krajiny.</string>
  <string name="wifi_ap_choose_disabled">Vypnuté</string>
  <string name="wifi_ap_choose_G">Pásmo %s GHz</string>
  <string name="wifi_hotspot_acs_channel_2g">Povolené kanály ACS 2.4 GHz</string>
  <string name="wifi_hotspot_acs_channel_5g">Povolené kanály ACS 5 GHz</string>
  <string name="wifi_hotspot_acs_channel_6g">Povolené kanály ACS 6 GHz</string>
  <string name="wifi_hotspot_acs_channel_help">Čísla kanálov povolené pre Automatic Channel Selection v tomto pásme. Zadajte kanály alebo rozsahy oddelené čiarkami, napr. &lt;tt&gt;1,6,11&lt;/tt&gt; alebo &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Ponechajte prázdne, aby boli povolené všetky kanály v pásme. Vyžaduje podporu ACS offload; inak Android toto nastavenie ignoruje.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Maximálna šírka kanála</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Obmedzuje šírku kanála Soft AP. Auto umožní Androidu použiť maximálnu šírku dosiahnuteľnú na zariadení.</string>
  <string name="wifi_channel_width_auto">Automat.</string>
  <string name="wifi_channel_width_invalid">Neplatné</string>
  <string name="wifi_hotspot_access_control_title">Riadenie prístupu</string>
  <string name="wifi_hotspot_ap_advanced_title">Rozšírené možnosti</string>
  <string name="wifi_advanced_mac_address_title">Adresa MAC</string>
  <string name="wifi_mac_address_persistent_randomization">Trvalá randomizácia: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Netrvalá randomizácia</string>
  <string name="wifi_mac_address_help">Nakonfigurujte BSSID a randomizáciu MAC pre AP. Android odmieta BSSID so samými nulami, multicast a broadcast. Výslovný BSSID sa použije iba pri vypnutej randomizácii MAC.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Trvalá náhodná MAC adresa</string>
  <string name="wifi_hidden_network">Skrytá sieť</string>
  <string name="wifi_hidden_network_help">Nevysielať SSID</string>
  <string name="wifi_max_clients">Maximálny počet klientov</string>
  <string name="wifi_max_clients_help">Maximálny počet klientov, ktorí sa môžu priradiť k AP. Prázdna hodnota nechá Android použiť limit zariadenia alebo operátora; klienti nad limit sa odmietnu.</string>
  <string name="wifi_blocked_list">Zoznam blokovaných klientov</string>
  <string name="wifi_blocked_list_help">MAC adresy, ktoré sa nemôžu priradiť k Soft AP. Vyžaduje podporu vynúteného odpojenia klienta; inak sa hotspot nemusí spustiť s chybou nepodporovanej konfigurácie.</string>
  <string name="wifi_client_user_control">Používateľské riadenie priradenia klientov</string>
  <string name="wifi_client_user_control_help">Vypnuté: každý klient mimo zoznamu blokovaných sa môže pripojiť so správnymi údajmi, kým sa hotspot nezaplní; zoznam povolených sa ignoruje. Zapnuté: Android používa zoznamy povolených a blokovaných na prijatie, odmietnutie alebo žiadosť o schválenie. Vyžaduje vynútené odpojenie klienta.</string>
  <string name="wifi_allowed_list">Zoznam povolených klientov</string>
  <string name="wifi_client_lists_overlap_error">MAC adresa existuje v oboch zoznamoch klientov</string>
  <string name="wifi_mac_randomization_none">Bez randomizácie</string>
  <string name="wifi_mac_randomization_none_help">Použiť továrenskú alebo výslovne nakonfigurovanú MAC adresu AP.</string>
  <string name="wifi_mac_randomization_persistent">Trvalá randomizácia</string>
  <string name="wifi_mac_randomization_persistent_help">Vygeneruje náhodnú MAC adresu AP, ktorá sa zachová pre SSID, kým SSID zostáva rovnaké.</string>
  <string name="wifi_mac_randomization_non_persistent">Netrvalá randomizácia</string>
  <string name="wifi_mac_randomization_non_persistent_help">Vygeneruje náhodnú MAC adresu AP vždy, keď sa AP znova povolí.</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown">Oportunistické vypnutie v premostenom režime</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown_help">V režime bridged AP môže Android vypnúť nečinnú inštanciu AP po bridged timeout: %s</string>
  <string name="wifi_hotspot_timeout_bridged">Časový limit nečinnosti pre premostenú inštanciu</string>
  <string name="wifi_hotspot_timeout_bridged_help">Nastavte, ako dlho nečinná inštancia bridged AP čaká pred oportunistickým vypnutím. Ak sú obe inštancie nečinné, Android vypne inštanciu s vyššou frekvenciou. Celkový timeout hotspotu sa stále uplatňuje samostatne.&lt;br&gt;&lt;br&gt;Predvolené: %s</string>
