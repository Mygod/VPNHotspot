  <string name="wifi_mac_address_persistent_randomization">Uwekaji nasibu endelevu: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Uwekaji nasibu usio endelevu</string>
  <string name="wifi_mac_address_help">Sanidi BSSID na uwekaji nasibu wa MAC kwa AP. Android hukataa BSSID za sufuri zote, multicast na broadcast. BSSID iliyo wazi hutumiwa tu wakati uwekaji nasibu wa MAC umezimwa.</string>
  <string name="wifi_p2p_mac_address_help">Chagua kama hali ya Supplicant ihifadhi anwani thabiti ya MAC au iombe ubadilishaji nasibu usio wa kudumu.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Anwani ya MAC nasibu endelevu</string>
  <string name="wifi_hidden_network">Mtandao uliofichwa</string>
  <string name="wifi_hidden_network_help">Usitangaze SSID</string>
  <string name="wifi_max_clients">Idadi ya juu ya wateja</string>
  <string name="wifi_max_clients_help">Idadi ya juu ya wateja wanaoweza kuhusishwa na AP. Ikiwa tupu, Android hutumia kikomo cha kifaa au mtoa huduma; wateja juu ya kikomo hukataliwa.</string>
  <string name="wifi_blocked_list">Orodha ya wateja waliozuiwa</string>
  <string name="wifi_blocked_list_help">Anwani za MAC ambazo haziwezi kuhusishwa na Soft AP. Inahitaji usaidizi wa kukata mteja kwa lazima; vinginevyo hotspot inaweza kushindwa kuanza kwa kosa la usanidi usiotumika.</string>
  <string name="wifi_client_user_control">Udhibiti wa mtumiaji wa kuhusisha wateja</string>
  <string name="wifi_client_user_control_help">Zima: mteja yeyote nje ya orodha iliyozuiwa anaweza kuunganisha kwa taarifa sahihi hadi hotspot ijae; orodha iliyoruhusiwa hupuuziwa. Washa: Android hutumia orodha zilizoruhusiwa na zilizozuiwa kukubali, kukataa au kuomba idhini. Inahitaji kukata mteja kwa lazima.</string>
  <string name="wifi_allowed_list">Orodha ya wateja walioruhusiwa</string>
  <string name="wifi_client_lists_overlap_error">Anwani ya MAC iko kwenye orodha zote mbili za wateja</string>
  <string name="wifi_mac_randomization_none">Hakuna uwekaji nasibu</string>
  <string name="wifi_mac_randomization_none_help">Tumia anwani ya MAC ya AP ya kiwandani au iliyosanidiwa wazi.</string>
  <string name="wifi_mac_randomization_persistent">Uwekaji nasibu endelevu</string>
  <string name="wifi_mac_randomization_persistent_help">Hutengeneza anwani ya MAC ya AP nasibu inayohifadhiwa kwa kila SSID mradi SSID ibaki ile ile.</string>
  <string name="wifi_mac_randomization_non_persistent">Uwekaji nasibu usio endelevu</string>
  <string name="wifi_mac_randomization_non_persistent_help">Hutengeneza anwani ya MAC ya AP nasibu kila AP inapowezeshwa tena.</string>
