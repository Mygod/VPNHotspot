  <string name="settings_service_ipv6_mode">IPv6 rejimi</string>
  <string name="settings_service_ipv6_mode_block">Bloklash</string>
  <string name="settings_service_ipv6_mode_system">Tizim</string>
  <string name="settings_service_ipv6_mode_nat">NAT (foydalanuvchi maydoni)</string>
  <string name="settings_service_upstream_help">Pastki oqim trafikini qayta marshrutlash uchun ishlatiladigan asosiy yuqori oqim interfeysi regex-i. VPN Hotspot o‘zi ishlashi uchun shu VPN-dan foydalanishga ruxsatli bo‘lishi kerak. VPN orqali tetheringni bostirish uchun &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; yoki boshqa noto‘g‘ri regex ishlating.</string>
  <string name="settings_upstream_fallback_help">VPN ayrim marshrutlarni standart tarmoqda qoldirganda zaxira yuqori oqim ishlatiladi. Zaxirani taqiqlash uchun &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; yoki boshqa noto‘g‘ri regex ishlating.</string>
  <string name="settings_service_masquerade_none_summary">Downstream manba manzillari yoki portlarini qayta yozmang. Bu reklama bloklagichlari yoki socksifier kabi dummy VPNlar bilan yaxshiroq ishlashi mumkin, lekin haqiqiy VPNlar bilan ishlatilmasligi kerak.</string>
  <string name="settings_service_masquerade_simple_summary">Ilovaga tegishli routing qoidalarida downstream manba manzillari va portlarini qayta yozing.</string>
  <string name="settings_service_masquerade_netd_summary">Masquerade-ni bajarishni Android &lt;tt&gt;netd&lt;/tt&gt; xizmatiga topshiring. Android &lt;tt&gt;FTP&lt;/tt&gt; ishlovi va tethering hisoblagichlari kabi platforma qo‘shimchalarini qo‘shishi mumkin, ammo tethering faoliyatini operatordan yashirish kerak bo‘lsa, bu mos emas.</string>
  <string name="settings_service_ipv6_mode_system_summary">IPv6 ishlovini platformaning marshrutlash sozlamasiga qoldiradi.</string>
  <string name="settings_service_ipv6_mode_block_summary">Quyi interfeyslarda IPv6 sizib chiqishining oldini oladi.</string>
  <string name="settings_service_ipv6_mode_nat_summary">Ilovaga tegishli deterministik ULA &lt;tt&gt;/64&lt;/tt&gt; tayinlaydi va root daemon orqali quyi IPv6 &lt;tt&gt;TCP&lt;/tt&gt;/&lt;tt&gt;UDP&lt;/tt&gt; hamda best-effort &lt;tt&gt;ICMPv6&lt;/tt&gt; proxy qiladi. Bu foydalanuvchi maydonidagi ish, to‘liq packet NAT emas, va boshqa IPv6 next-header protocols yo‘naltirilmaydi.</string>
  <string name="settings_service_auto_start">Xizmatlarni avtomatik boshlash</string>
  <string name="settings_service_auto_start_summary">Qurilma qayta ishga tushishi yoki ilova yangilanishidan oldin ishlayotgan xizmatlarni tiklash.</string>
  <string name="settings_service_repeater_safe_mode">Repeater xavfsiz rejimi</string>
  <string name="settings_service_repeater_safe_mode_summary">Tizim konfiguratsiyasiga o‘zgartirish kiritmaydi, ammo qisqa tarmoq nomlari bilan ishlamasligi mumkin. Xavfsiz bo‘lmagan rejim qurilmangizda ishlamasligi va uni tiklab bo‘ladigan tarzda vaqtincha yaroqsiz qilishi mumkin.</string>
  <string name="settings_service_repeater_safe_mode_warning">Qisqa tarmoq nomlari xavfsiz rejimni o‘chirishni talab qilishi mumkin.</string>
  <string name="settings_service_temp_hotspot_use_system">Vaqtinchalik hotspot uchun tizim konfiguratsiyasidan foydalanish</string>
  <string name="settings_service_temp_hotspot_use_system_summary">Faqat mahalliy hotspot ishlatadigan boshqa ilovalar bilan ziddiyatga kiradi. Tizim ilovasi sifatida o‘rnatilmagan bo‘lsa, fonda ko‘proq resurs ham ishlatadi.</string>
  <string name="settings_service_temp_hotspot_use_system_summary_api30">Faqat mahalliy hotspot ishlatadigan boshqa ilovalar bilan ziddiyatga kiradi. Tizim ilovasi sifatida o‘rnatilmagan bo‘lsa, fonda ko‘proq resurs ham ishlatadi. Ehtimol Android 12 yoki yangiroqda ishlaydi.</string>
  <string name="settings_service_wifi_lock">Wi‑Fi-ni faol saqlash</string>
