  <string name="wifi_hotspot_ap_band_title">Wi-Fi diapazoni</string>
  <string name="wifi_hotspot_ap_channel_band_title">AP kanali/diapazoni</string>
  <string name="wifi_hotspot_ap_channel_band_help">Qo‘llanmaydigan diapazon/kanal hotspot boshlanishining muvaffaqiyatsiz bo‘lishiga sabab bo‘lishi mumkin.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Bir vaqtdagi AP kanali/diapazoni</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">bridged AP concurrency qo‘llansa, ikkinchi AP instance qo‘shadi. Qo‘llanmaydigan band/channel kombinatsiyalari hotspot ishga tushganda muvaffaqiyatsiz bo‘lishi mumkin.</string>
  <string name="wifi_band_optimization">Diapazon optimallashtirishni yoqish</string>
  <string name="wifi_band_optimization_help">Android diapazon sozlamalarini optimallashtirishiga imkon beradi, masalan birga ishlash yoki mamlakat kodi cheklovlari uchun 2.4 GHz diapazonini qo‘shish.</string>
  <string name="wifi_ap_choose_disabled">Yoqilmagan</string>
  <string name="wifi_ap_choose_G">%s GHz diapazoni</string>
  <string name="wifi_hotspot_acs_channel_2g">Ruxsat etilgan 2.4 GHz ACS kanallari</string>
  <string name="wifi_hotspot_acs_channel_5g">Ruxsat etilgan 5 GHz ACS kanallari</string>
  <string name="wifi_hotspot_acs_channel_6g">Ruxsat etilgan 6 GHz ACS kanallari</string>
  <string name="wifi_hotspot_acs_channel_help">Bu band ichida Automatic Channel Selection uchun ruxsat etilgan channel numbers. Vergul bilan ajratilgan channels yoki ranges kiriting, masalan &lt;tt&gt;1,6,11&lt;/tt&gt; yoki &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Banddagi barcha channels ga ruxsat berish uchun bo‘sh qoldiring. ACS offload support kerak; aks holda Android bu settingni ignore qiladi.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Kanalning eng katta o‘tkazish kengligi</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Soft AP kanal o‘tkazish kengligini cheklaydi. Auto Androidga qurilmada erishiladigan eng katta kenglikdan foydalanishga imkon beradi.</string>
  <string name="wifi_channel_width_auto">Avto</string>
  <string name="wifi_channel_width_invalid">Yaroqsiz</string>
  <string name="wifi_hotspot_access_control_title">Kirish nazorati</string>
  <string name="wifi_hotspot_ap_advanced_title">Kengaytirilgan sozlamalar</string>
  <string name="wifi_advanced_mac_address_title">MAC manzil</string>
  <string name="wifi_mac_address_persistent_randomization">Doimiy tasodifiylashtirish: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Doimiy bo‘lmagan tasodifiylashtirish</string>
  <string name="wifi_mac_address_help">AP uchun BSSID va MAC tasodifiylashtirishni sozlang. Android hammasi nol, multicast va broadcast BSSIDlarni rad etadi. Aniq BSSID faqat MAC tasodifiylashtirish o‘chirilganda ishlatiladi.</string>
  <string name="wifi_p2p_mac_address_help">Takrorlagich ishlatadigan P2P qurilma manzilini sozlang. Android manzilni tanlashi uchun bo‘sh qoldiring.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Doimiy tasodifiy MAC manzil</string>
  <string name="wifi_hidden_network">Yashirin tarmoq</string>
  <string name="wifi_hidden_network_help">SSID-ni tarqatmaslik</string>
  <string name="wifi_max_clients">Mijozlarning eng ko‘p soni</string>
  <string name="wifi_max_clients_help">AP bilan bog‘lana oladigan mijozlarning eng ko‘p soni. Bo‘sh bo‘lsa, Android qurilma yoki operator chegarasidan foydalanadi; chegaradan oshgan mijozlar rad etiladi.</string>
  <string name="wifi_blocked_list">Bloklangan mijozlar ro‘yxati</string>
  <string name="wifi_blocked_list_help">Soft AP bilan bog‘lana olmaydigan MAC manzillar. Mijozni majburan uzish qo‘llovi kerak; aks holda hotspot qo‘llanmaydigan konfiguratsiya xatosi bilan boshlanmasligi mumkin.</string>
  <string name="wifi_client_user_control">Mijoz bog‘lanishini foydalanuvchi boshqaruvi</string>
  <string name="wifi_client_user_control_help">O‘chiq: bloklangan ro‘yxatdan tashqaridagi har qanday mijoz to‘g‘ri ma’lumotlar bilan hotspot to‘lguncha ulanishi mumkin; ruxsat berilgan ro‘yxat e’tiborga olinmaydi. Yoniq: Android ruxsat berilgan va bloklangan ro‘yxatlar bilan qabul qiladi, rad etadi yoki tasdiq so‘raydi. Mijozni majburan uzish kerak.</string>
  <string name="wifi_allowed_list">Ruxsat berilgan mijozlar ro‘yxati</string>
  <string name="wifi_client_lists_overlap_error">MAC manzil ikkala mijoz ro‘yxatida ham bor</string>
  <string name="wifi_mac_randomization_none">Tasodifiylashtirish yo‘q</string>
  <string name="wifi_mac_randomization_none_help">Zavod yoki aniq sozlangan AP MAC manzilidan foydalanish.</string>
  <string name="wifi_mac_randomization_persistent">Doimiy tasodifiylashtirish</string>
  <string name="wifi_mac_randomization_persistent_help">SSID o‘zgarmagancha har bir SSID uchun saqlanadigan tasodifiy AP MAC manzil yaratadi.</string>
  <string name="wifi_mac_randomization_non_persistent">Doimiy bo‘lmagan tasodifiylashtirish</string>
  <string name="wifi_mac_randomization_non_persistent_help">AP qayta yoqilgan har safar tasodifiy AP MAC manzil yaratadi.</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown">Ko‘prik rejimida opportunistik o‘chirish</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown_help">bridged AP mode ichida Android bridged timeoutdan keyin idle AP instanceni o‘chirishi mumkin: %s</string>
  <string name="wifi_hotspot_timeout_bridged">Ko‘prik instansiyasi uchun bekor turish vaqti</string>
  <string name="wifi_hotspot_timeout_bridged_help">opportunistic shutdown oldidan idle bridged AP instance qancha kutishini configure qiling. Ikkala instance ham idle bo‘lsa, Android higher-frequency instanceni o‘chiradi. overall hotspot timeout alohida amal qilishda davom etadi.&lt;br&gt;&lt;br&gt;Default: %s</string>
