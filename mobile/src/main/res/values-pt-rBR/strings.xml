  <string name="wifi_hotspot_ap_advanced_title">Opções avançadas</string>
  <string name="wifi_advanced_mac_address_title">Endereço MAC</string>
  <string name="wifi_mac_address_persistent_randomization">Aleatorização persistente: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Aleatorização não persistente</string>
  <string name="wifi_mac_address_help">Configure o BSSID e a aleatorização de MAC do AP. O Android rejeita BSSID só com zeros, multicast e broadcast. Um BSSID explícito só é usado quando a aleatorização de MAC está desativada.</string>
  <string name="wifi_p2p_mac_address_help">Configure o endereço do dispositivo P2P usado pelo repetidor. Deixe vazio para o Android escolher o endereço.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Endereço MAC aleatório persistente</string>
  <string name="wifi_hidden_network">Rede oculta</string>
  <string name="wifi_hidden_network_help">Não transmitir o SSID</string>
  <string name="wifi_max_clients">Número máximo de clientes</string>
  <string name="wifi_max_clients_help">Número máximo de clientes que podem se associar ao AP. Se vazio, o Android usa o limite do dispositivo ou da operadora; clientes acima do limite são rejeitados.</string>
  <string name="wifi_blocked_list">Lista de clientes bloqueados</string>
  <string name="wifi_blocked_list_help">Endereços MAC que não podem se associar ao Soft AP. Requer suporte a desconexão forçada de clientes; caso contrário, o hotspot pode falhar ao iniciar com erro de configuração incompatível.</string>
  <string name="wifi_client_user_control">Controle de qual cliente pode usar o hotspot</string>
  <string name="wifi_client_user_control_help">Desativado: qualquer cliente fora da lista bloqueada pode se conectar com as credenciais corretas até o hotspot lotar; a lista permitida é ignorada. Ativado: o Android usa as listas permitida e bloqueada para aceitar, rejeitar ou pedir aprovação. Requer desconexão forçada de clientes.</string>
  <string name="wifi_allowed_list">Lista de clientes permitidos</string>
  <string name="wifi_client_lists_overlap_error">Um endereço MAC existe nas duas listas de clientes</string>
  <string name="wifi_mac_randomization_none">Nenhum</string>
  <string name="wifi_mac_randomization_none_help">Usar o endereço MAC do AP de fábrica ou configurado explicitamente.</string>
  <string name="wifi_mac_randomization_persistent">Persistente</string>
  <string name="wifi_mac_randomization_persistent_help">Gera um endereço MAC de AP aleatório preservado por SSID enquanto o SSID permanecer igual.</string>
  <string name="wifi_mac_randomization_non_persistent">Não persistente</string>
  <string name="wifi_mac_randomization_non_persistent_help">Gera um endereço MAC de AP aleatório sempre que o AP é reativado.</string>
