  <string name="wifi_hotspot_timeout">Tempo inativo</string>
  <string name="wifi_hotspot_timeout_help">Configure quanto tempo aguardar sem dispositivos conectados antes do desligamento automático.&lt;br&gt;&lt;br&gt;Padrão: %s</string>
