  <string name="wifi_vendor_data_error_incomplete_xml">Неполный XML данных производителя для OUI %1$s</string>
  <string name="wifi_client_isolation">Изоляция клиентов</string>
  <string name="wifi_client_isolation_help">Запретить подключённым клиентам взаимодействовать с другими подключёнными клиентами</string>
