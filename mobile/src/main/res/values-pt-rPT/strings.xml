  <string name="wifi_hotspot_timeout">Tempo inativo</string>
  <string name="wifi_hotspot_timeout_help">Configure o tempo a aguardar sem dispositivos ligados antes do encerramento automático.&lt;br&gt;&lt;br&gt;Predefinição: %s</string>
