  <string name="wifi_hotspot_ap_band_title">Banda do PA</string>
  <string name="wifi_hotspot_ap_channel_band_title">Canal/banda do AP</string>
  <string name="wifi_hotspot_ap_channel_band_help">Uma banda ou canal não suportado pode fazer o hotspot falhar ao iniciar.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Canal/banda de AP concorrente</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">Adiciona uma segunda instância AP quando a simultaneidade AP em ponte é suportada. Combinações de banda/canal não suportadas podem falhar ao iniciar o ponto de acesso.</string>
  <string name="wifi_band_optimization">Ativar otimização de banda</string>
  <string name="wifi_band_optimization_help">Permite que o Android otimize as definições de banda, como adicionar a banda de 2.4 GHz por coexistência ou restrições de código de país.</string>
  <string name="wifi_ap_choose_disabled">Desativado</string>
  <string name="wifi_ap_choose_G">%s GHz</string>
  <string name="wifi_hotspot_acs_channel_2g">Canais permitidos 2.4 GHz ACS</string>
  <string name="wifi_hotspot_acs_channel_5g">Canais permitidos 5 GHz ACS</string>
  <string name="wifi_hotspot_acs_channel_6g">Canais permitidos 6 GHz ACS</string>
  <string name="wifi_hotspot_acs_channel_help">Números de canal permitidos para a seleção automática de canal nesta banda. Introduza canais ou intervalos separados por vírgulas, como &lt;tt&gt;1,6,11&lt;/tt&gt; ou &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Deixe vazio para permitir todos os canais da banda. Requer suporte ACS offload; caso contrário, o Android ignora esta definição.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Largura máxima do canal</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Limita a largura do canal do Soft AP. Auto permite que o Android use a largura máxima possível no dispositivo.</string>
  <string name="wifi_channel_width_auto">Automático</string>
  <string name="wifi_channel_width_invalid">Inválido</string>
