  <string name="wifi_mac_address_persistent_randomization">Persistente randomisatie: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Niet-persistente randomisatie</string>
  <string name="wifi_mac_address_help">Configureer BSSID en MAC-randomisatie voor de AP. Android weigert BSSID\'s met alleen nullen, multicast en broadcast. Een expliciete BSSID wordt alleen gebruikt wanneer MAC-randomisatie is uitgeschakeld.</string>
  <string name="wifi_p2p_mac_address_help">Configureer het P2P-apparaatadres dat door de repeater wordt gebruikt. Laat leeg om Android het adres te laten kiezen.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Persistent willekeurig MAC-adres</string>
  <string name="wifi_hidden_network">Verborgen netwerk</string>
  <string name="wifi_hidden_network_help">SSID niet uitzenden</string>
  <string name="wifi_max_clients">Maximumaantal clients</string>
  <string name="wifi_max_clients_help">Maximumaantal clients dat met de AP kan associëren. Leeg laat Android de apparaat- of providerlimiet gebruiken; clients boven de limiet worden geweigerd.</string>
  <string name="wifi_blocked_list">Lijst met geblokkeerde clients</string>
  <string name="wifi_blocked_list_help">MAC-adressen die niet met de Soft AP kunnen associëren. Vereist ondersteuning voor geforceerd verbreken van clients; anders kan de hotspot mislukken bij het starten met een fout voor niet-ondersteunde configuratie.</string>
  <string name="wifi_client_user_control">Gebruikerscontrole van clientassociatie</string>
  <string name="wifi_client_user_control_help">Uit: elke client buiten de geblokkeerde lijst kan met de juiste gegevens verbinden totdat de hotspot vol is; de toegestane lijst wordt genegeerd. Aan: Android gebruikt de toegestane en geblokkeerde lijsten om te accepteren, weigeren of goedkeuring te vragen. Vereist geforceerd verbreken van clients.</string>
  <string name="wifi_allowed_list">Lijst met toegestane clients</string>
  <string name="wifi_client_lists_overlap_error">Een MAC-adres staat in beide clientlijsten</string>
  <string name="wifi_mac_randomization_none">Geen randomisatie</string>
  <string name="wifi_mac_randomization_none_help">Gebruik het fabrieks- of expliciet geconfigureerde AP-MAC-adres.</string>
  <string name="wifi_mac_randomization_persistent">Persistente randomisatie</string>
  <string name="wifi_mac_randomization_persistent_help">Genereert een willekeurig AP-MAC-adres dat per SSID behouden blijft zolang de SSID hetzelfde blijft.</string>
  <string name="wifi_mac_randomization_non_persistent">Niet-persistente randomisatie</string>
  <string name="wifi_mac_randomization_non_persistent_help">Genereert een willekeurig AP-MAC-adres telkens wanneer de AP opnieuw wordt ingeschakeld.</string>
