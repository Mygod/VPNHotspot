  <string name="settings_service_upstream_help">Regex for hoved-oppstrømsgrensesnittet som brukes til å omdirigere nedstrømstrafikk. VPN Hotspot må selv ha lov til å bruke den VPN-en for å fungere. Bruk &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; eller en annen ugyldig regex for å undertrykke deling gjennom VPN.</string>
  <string name="settings_upstream_fallback_help">Reserve-oppstrøm brukes når en VPN lar noen ruter ligge på standardnettverket. Bruk &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; eller en annen ugyldig regex for å forby reserve.</string>
  <string name="settings_service_masquerade_none_summary">Ikke skriv om nedstrøms kildeadresser eller porter. Dette kan fungere bedre med falske VPN-er som annonseblokkere eller socksifiere, men bør ikke brukes med ekte VPN-er.</string>
  <string name="settings_service_masquerade_simple_summary">Skriv om nedstrøms kildeadresser og porter i appens egne rutingregler.</string>
  <string name="settings_service_masquerade_netd_summary">Be Android &lt;tt&gt;netd&lt;/tt&gt; håndtere masquerade. Android kan legge til plattformtillegg som &lt;tt&gt;FTP&lt;/tt&gt;-håndtering og tethering-tellere, men dette passer dårlig når tethering-aktivitet skal skjules for operatøren.</string>
  <string name="settings_service_ipv6_mode_system_summary">Overlat IPv6-håndtering til plattformens rutingoppsett.</string>
  <string name="settings_service_ipv6_mode_block_summary">Forhindrer IPv6-lekkasjer på nedstrømsgrensesnitt.</string>
  <string name="settings_service_ipv6_mode_nat_summary">Tildeler en deterministisk app-eid ULA &lt;tt&gt;/64&lt;/tt&gt; og proxyer nedstrøms IPv6 &lt;tt&gt;TCP&lt;/tt&gt;/&lt;tt&gt;UDP&lt;/tt&gt; pluss best-effort &lt;tt&gt;ICMPv6&lt;/tt&gt; gjennom root-daemonen. Dette er arbeid i brukerrom, ikke full pakke-NAT, og videresender ikke andre IPv6 next-header-protokoller.</string>
  <string name="settings_service_auto_start">Start tjenester automatisk</string>
  <string name="settings_service_auto_start_summary">Gjenopprett tjenester hvis de kjørte før enheten startet på nytt eller appen ble oppdatert.</string>
  <string name="settings_service_repeater_supplicant_mode_warning">Korte nettverksnavn kan kreve Supplicant-modus</string>
  <string name="settings_service_temp_hotspot_use_system">Bruk systemkonfigurasjon for midlertidig hotspot</string>
  <string name="settings_service_temp_hotspot_use_system_summary">Vil komme i konflikt med andre apper som bruker lokal hotspot. Bruker også flere ressurser i bakgrunnen med mindre den er installert som systemapp.</string>
  <string name="settings_service_temp_hotspot_use_system_summary_api30">Vil komme i konflikt med andre apper som bruker lokal hotspot. Bruker også flere ressurser i bakgrunnen med mindre den er installert som systemapp. Fungerer mest sannsynlig på Android 12 eller nyere.</string>
