  <string name="wifi_hotspot_timeout">Timeout sa pag-shutdown</string>
  <string name="wifi_hotspot_timeout_help">I-configure ang oras ng paghihintay nang walang nakakonektang device bago ang auto shutdown.&lt;br&gt;&lt;br&gt;Default: %s</string>
  <string name="wifi_hotspot_ap_band_title">AP band</string>
  <string name="wifi_hotspot_ap_channel_band_title">Channel/band ng AP</string>
  <string name="wifi_hotspot_ap_channel_band_help">Maaaring mabigong magsimula ang hotspot dahil sa hindi sinusuportahang band/channel.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Kasabay na channel/band ng AP</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">Nagdaragdag ng pangalawang AP instance kapag supported ang bridged AP concurrency. Maaaring mag-fail ang unsupported band/channel combination kapag nagsisimula ang hotspot.</string>
  <string name="wifi_band_optimization">I-enable ang pag-optimize ng band</string>
  <string name="wifi_band_optimization_help">Hinahayaan ang Android na i-optimize ang mga setting ng band, gaya ng pagdagdag ng 2.4 GHz band para sa coexistence o mga paghihigpit sa country code.</string>
  <string name="wifi_ap_choose_disabled">Naka-disable</string>
  <string name="wifi_ap_choose_G">%s GHz band</string>
  <string name="wifi_hotspot_acs_channel_2g">Pinapayagang 2.4 GHz ACS channels</string>
  <string name="wifi_hotspot_acs_channel_5g">Pinapayagang 5 GHz ACS channels</string>
  <string name="wifi_hotspot_acs_channel_6g">Pinapayagang 6 GHz ACS channels</string>
  <string name="wifi_hotspot_acs_channel_help">Mga channel number na pinapayagan para sa Automatic Channel Selection sa band na ito. Maglagay ng comma-separated channels o ranges, gaya ng &lt;tt&gt;1,6,11&lt;/tt&gt; o &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Iwanang blank para payagan ang lahat ng channels sa band. Kailangan ng ACS offload support; kung hindi, ini-ignore ng Android ang setting na ito.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Maximum na bandwidth ng channel</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Nililimitahan ang bandwidth ng channel ng Soft AP. Hinahayaan ng Auto ang Android na gamitin ang maximum na bandwidth na kaya ng device.</string>
  <string name="wifi_channel_width_auto">Awtomatiko</string>
  <string name="wifi_channel_width_invalid">Di-wasto</string>
  <string name="wifi_standard_legacy">Lumang Wi‑Fi</string>
  <string name="wifi_hotspot_access_control_title">Kontrol sa access</string>
  <string name="wifi_hotspot_ap_advanced_title">Mga advanced na opsyon</string>
  <string name="wifi_mac_address_persistent_randomization">Persistent na randomization: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Hindi persistent na randomization</string>
  <string name="wifi_mac_address_help">I-configure ang BSSID at MAC randomization para sa AP. Tinatanggihan ng Android ang all-zero, multicast, at broadcast BSSID. Ginagamit lang ang tahasang BSSID kapag naka-disable ang MAC randomization.</string>
  <string name="wifi_p2p_mac_address_help">Piliin kung pananatilihin ng Supplicant mode ang stable na MAC address o hihiling ng non-persistent randomization.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Persistent randomized MAC address</string>
  <string name="wifi_hidden_network">Nakatagong network</string>
  <string name="wifi_hidden_network_help">Huwag i-broadcast ang SSID</string>
  <string name="wifi_max_clients">Maximum na bilang ng kliyente</string>
  <string name="wifi_max_clients_help">Maximum na bilang ng kliyenteng maaaring makiugnay sa AP. Kapag walang laman, gagamitin ng Android ang limitasyon ng device o carrier; tatanggihan ang mga kliyenteng lampas sa limitasyon.</string>
  <string name="wifi_blocked_list">Listahan ng mga naka-block na kliyente</string>
  <string name="wifi_blocked_list_help">Mga MAC address na hindi maaaring makiugnay sa Soft AP. Kailangan ang suporta sa puwersahang pag-disconnect ng kliyente; kung hindi, maaaring mabigong magsimula ang hotspot dahil sa hindi sinusuportahang configuration.</string>
  <string name="wifi_client_user_control">Kontrol ng user sa pag-uugnay ng kliyente</string>
  <string name="wifi_client_user_control_help">Naka-off: anumang kliyenteng wala sa blocked list ay makakakonekta gamit ang tamang credentials hanggang mapuno ang hotspot; binabalewala ang allowed list. Naka-on: ginagamit ng Android ang allowed at blocked lists para tanggapin, tanggihan, o humingi ng pag-apruba. Kailangan ang puwersahang pag-disconnect ng kliyente.</string>
  <string name="wifi_allowed_list">Listahan ng mga pinapayagang kliyente</string>
  <string name="wifi_client_lists_overlap_error">May MAC address sa parehong listahan ng kliyente</string>
  <string name="wifi_mac_randomization_none">Walang randomization</string>
  <string name="wifi_mac_randomization_none_help">Gamitin ang factory o tahasang naka-configure na AP MAC address.</string>
  <string name="wifi_mac_randomization_persistent">Persistent na randomization</string>
  <string name="wifi_mac_randomization_persistent_help">Gumagawa ng random na AP MAC address na pinapanatili bawat SSID habang hindi nagbabago ang SSID.</string>
  <string name="wifi_mac_randomization_non_persistent">Hindi persistent na randomization</string>
  <string name="wifi_mac_randomization_non_persistent_help">Gumagawa ng random na AP MAC address tuwing muling ine-enable ang AP.</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown">Opportunistic shutdown sa bridged mode</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown_help">Sa bridged AP mode, maaaring i-off ng Android ang idle AP instance pagkatapos ng bridged timeout: %s</string>
  <string name="wifi_hotspot_timeout_bridged">Inactive timeout para sa bridged instance</string>
  <string name="wifi_hotspot_timeout_bridged_help">I-configure kung gaano katagal maghihintay ang idle bridged AP instance bago ang opportunistic shutdown. Kung parehong idle ang instances, io-off ng Android ang instance na may mas mataas na frequency. Patuloy na hiwalay na nalalapat ang overall hotspot timeout.&lt;br&gt;&lt;br&gt;Default: %s</string>
