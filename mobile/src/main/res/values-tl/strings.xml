  <string name="wifi_password_help">Pre-shared key para sa personal na seguridad ng WPA2/WPA3. Dapat 8–63 character ang WPA2-PSK at WPA3-SAE transition passphrases.</string>
  <string name="wifi_hotspot_auto_off">Awtomatikong i-off ang hotspot</string>
