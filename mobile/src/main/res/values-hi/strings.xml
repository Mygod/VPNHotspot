  <string name="wifi_hotspot_ap_band_title">एपी बैंड</string>
  <string name="wifi_hotspot_ap_channel_band_title">AP चैनल/बैंड</string>
  <string name="wifi_hotspot_ap_channel_band_help">असमर्थित बैंड/चैनल के कारण हॉटस्पॉट शुरू होने में विफल हो सकता है।</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">समवर्ती AP चैनल/बैंड</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">bridged AP concurrency supported होने पर दूसरी AP instance जोड़ता है। unsupported band/channel combination hotspot शुरू होने पर fail हो सकते हैं।</string>
  <string name="wifi_band_optimization">बैंड ऑप्टिमाइज़ेशन चालू करें</string>
  <string name="wifi_band_optimization_help">Android को बैंड सेटिंग ऑप्टिमाइज़ करने देता है, जैसे सह-अस्तित्व या देश-कोड प्रतिबंधों के लिए 2.4 GHz बैंड जोड़ना।</string>
  <string name="wifi_ap_choose_disabled">अक्षम</string>
  <string name="wifi_ap_choose_G">%s GHz बैंड</string>
  <string name="wifi_hotspot_acs_channel_2g">अनुमत 2.4 GHz ACS चैनल</string>
  <string name="wifi_hotspot_acs_channel_5g">अनुमत 5 GHz ACS चैनल</string>
  <string name="wifi_hotspot_acs_channel_6g">अनुमत 6 GHz ACS चैनल</string>
  <string name="wifi_hotspot_acs_channel_help">इस band में Automatic Channel Selection के लिए अनुमत channel numbers। comma-separated channels या ranges डालें, जैसे &lt;tt&gt;1,6,11&lt;/tt&gt; या &lt;tt&gt;36-48,149-161&lt;/tt&gt;। band के सभी channels की अनुमति देने के लिए खाली छोड़ें। ACS offload support चाहिए; नहीं तो Android इस setting को ignore करता है।</string>
  <string name="wifi_hotspot_max_channel_bandwidth">अधिकतम चैनल बैंडविड्थ</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Soft AP चैनल बैंडविड्थ सीमित करता है। Auto Android को डिवाइस पर उपलब्ध अधिकतम बैंडविड्थ उपयोग करने देता है।</string>
  <string name="wifi_channel_width_auto">अपने आप</string>
  <string name="wifi_channel_width_invalid">अमान्य</string>
  <string name="wifi_hotspot_access_control_title">पहुंच नियंत्रण</string>
  <string name="wifi_hotspot_ap_advanced_title">बेहतर विकल्प</string>
  <string name="wifi_advanced_mac_address_title">MAC पता</string>
  <string name="wifi_mac_address_persistent_randomization">स्थायी रैंडमाइज़ेशन: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">अस्थायी रैंडमाइज़ेशन</string>
  <string name="wifi_mac_address_help">AP के लिए BSSID और MAC रैंडमाइज़ेशन कॉन्फ़िगर करें। Android सभी-शून्य, multicast और broadcast BSSID अस्वीकार करता है। स्पष्ट BSSID केवल तब उपयोग होता है जब MAC रैंडमाइज़ेशन बंद हो।</string>
  <string name="wifi_p2p_mac_address_help">रिपीटर द्वारा उपयोग किया गया P2P डिवाइस पता कॉन्फ़िगर करें। Android को पता चुनने देने के लिए खाली छोड़ें।</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">स्थायी रैंडमाइज़्ड MAC पता</string>
  <string name="wifi_hidden_network">छिपा हुआ नेटवर्क</string>
  <string name="wifi_hidden_network_help">SSID प्रसारित न करें</string>
  <string name="wifi_max_clients">क्लाइंट की अधिकतम संख्या</string>
  <string name="wifi_max_clients_help">AP से जुड़ सकने वाले क्लाइंट की अधिकतम संख्या। खाली छोड़ने पर Android डिवाइस या कैरियर की सीमा इस्तेमाल करता है; सीमा से ऊपर के क्लाइंट अस्वीकार किए जाते हैं।</string>
  <string name="wifi_blocked_list">ब्लॉक किए गए क्लाइंट की सूची</string>
  <string name="wifi_blocked_list_help">वे MAC पते जो Soft AP से नहीं जुड़ सकते। क्लाइंट को जबरन डिस्कनेक्ट करने का समर्थन आवश्यक है; अन्यथा हॉटस्पॉट असमर्थित कॉन्फ़िगरेशन त्रुटि के साथ शुरू होने में विफल हो सकता है।</string>
