  <string name="wifi_hotspot_timeout">Leállítási időkorlát</string>
  <string name="wifi_hotspot_timeout_help">Állítsa be, mennyi ideig várjon csatlakoztatott eszközök nélkül az automatikus leállítás előtt.&lt;br&gt;&lt;br&gt;Alapértelmezett: %s</string>
