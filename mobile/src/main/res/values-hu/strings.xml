  <string name="settings_service_upstream_help">A fő felsőbb interfész regexe az alsóbb forgalom újraútválasztásához. A VPN Hotspotnak magának is engedélyezve kell lennie, hogy használja ezt a VPN-t. A VPN-en keresztüli megosztás letiltásához használja a &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; vagy más érvénytelen regex értéket.</string>
  <string name="settings_upstream_fallback_help">A tartalék felsőbb akkor használatos, ha egy VPN néhány útvonalat az alapértelmezett hálózaton hagy. A tartalék tiltásához használja a &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; vagy más érvénytelen regex értéket.</string>
  <string name="settings_service_masquerade_none_summary">Ne írja át a downstream forráscímeket vagy portokat. Ez jobban működhet ál-VPN-ekkel, például hirdetésblokkolókkal vagy socksifierekkel, de valódi VPN-ekkel nem ajánlott használni.</string>
  <string name="settings_service_masquerade_simple_summary">Írja át a downstream forráscímeket és portokat az alkalmazás saját útválasztási szabályaiban.</string>
  <string name="settings_service_masquerade_netd_summary">Az Android &lt;tt&gt;netd&lt;/tt&gt; szolgáltatására bízza a masquerade kezelését. Az Android platformos kiegészítéseket adhat hozzá, például &lt;tt&gt;FTP&lt;/tt&gt;-kezelést és tethering-számlálókat, de ez rossz választás, ha a tethering tevékenységet el kell rejteni a szolgáltató elől.</string>
  <string name="settings_service_ipv6_mode_system_summary">Az IPv6 kezelését a platform útválasztási beállításaira bízza.</string>
  <string name="settings_service_ipv6_mode_block_summary">Megakadályozza az IPv6-szivárgást az alsó interfészeken.</string>
  <string name="settings_service_ipv6_mode_nat_summary">Deterministic, alkalmazás tulajdonú ULA &lt;tt&gt;/64&lt;/tt&gt;-et rendel hozzá, és a root daemonon keresztül proxizza az alsó IPv6 &lt;tt&gt;TCP&lt;/tt&gt;/&lt;tt&gt;UDP&lt;/tt&gt;-t, valamint best-effort &lt;tt&gt;ICMPv6&lt;/tt&gt;-ot. Ez felhasználói térben végzett munka, nem teljes packet NAT, és nem továbbít más IPv6 next-header protokollokat.</string>
  <string name="settings_service_auto_start">Szolgáltatások automatikus indítása</string>
  <string name="settings_service_auto_start_summary">Állítsa vissza a szolgáltatásokat, ha az eszköz újraindítása vagy az alkalmazás frissítése előtt futottak.</string>
  <string name="settings_service_repeater_safe_mode">Ismétlő biztonságos módja</string>
  <string name="settings_service_repeater_safe_mode_summary">Nem módosítja a rendszer konfigurációját, de rövid hálózatnevekkel lehet, hogy nem működik. A nem biztonságos mód lehet, hogy nem működik az eszközén, és ideiglenesen, visszaállítható módon használhatatlanná teheti azt.</string>
  <string name="settings_service_repeater_safe_mode_warning">Rövid hálózatnevek esetén szükség lehet a biztonságos mód kikapcsolására.</string>
  <string name="settings_service_temp_hotspot_use_system">Rendszerkonfiguráció használata ideiglenes hotspothoz</string>
  <string name="settings_service_temp_hotspot_use_system_summary">Ütközni fog más, csak helyi hotspotot használó alkalmazásokkal. Több erőforrást is használ a háttérben, hacsak nincs rendszeralkalmazásként telepítve.</string>
  <string name="settings_service_temp_hotspot_use_system_summary_api30">Ütközni fog más, csak helyi hotspotot használó alkalmazásokkal. Több erőforrást is használ a háttérben, hacsak nincs rendszeralkalmazásként telepítve. Nagy valószínűséggel Android 12 vagy újabb rendszeren működik.</string>
  <string name="settings_service_wifi_lock">Wi‑Fi életben tartása</string>
  <string name="settings_service_wifi_lock_none">Rendszerbeállítás</string>
  <string name="settings_service_wifi_lock_high_perf_v29">Energiatakarékosság kikapcsolása</string>
  <string name="settings_service_wifi_lock_low_latency">Alacsony késleltetésű mód</string>
  <string name="settings_service_wifi_lock_none_summary">Az akkumulátor kímélése érdekében a rendszer alapértelmezett Wi‑Fi energiahasználati viselkedését használja.</string>
  <string name="settings_service_wifi_lock_high_perf_v29_summary">Csökkenti a csomagkésleltetést például hanghívásoknál a képernyő kikapcsolása után. Hardvertámogatás szükséges. Android 14 és újabb rendszeren ezt az elavult módot az alacsony késleltetésű mód váltja fel.</string>
  <string name="settings_service_wifi_lock_low_latency_summary">Késleltetésre érzékeny használatra optimalizál, például játékhoz vagy virtuális valósághoz. Csökkentheti az akkumulátoridőt, az átviteli sebességet, a Wi‑Fi-keresés gyakoriságát, a barangolás minőségét és a helymeghatározás pontosságát. Hardvertámogatás szükséges, valamint az alkalmazásnak bekapcsolt képernyő mellett előtérben kell futnia.</string>
  <string name="settings_service_upstream">Felsőbb hálózati interfész</string>
  <string name="settings_service_upstream_auto">Rendszer-VPN automatikus észlelése</string>
  <string name="settings_upstream_fallback">Tartalék felsőbb interfész</string>
  <string name="settings_upstream_fallback_auto">Rendszer alapértelmezett hálózatának automatikus észlelése</string>
