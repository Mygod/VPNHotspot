  <string name="wifi_hotspot_ap_channel_band_title">AP-csatorna/sáv</string>
  <string name="wifi_hotspot_ap_channel_band_help">A nem támogatott sáv/csatorna miatt a hotspot indítása meghiúsulhat.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Egyidejű AP-csatorna/sáv</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">Második AP-példányt ad hozzá, ha a bridged AP egyidejűség támogatott. A nem támogatott sáv/csatorna kombinációk a hotspot indításakor meghiúsulhatnak.</string>
  <string name="wifi_band_optimization">Sávoptimalizálás engedélyezése</string>
  <string name="wifi_band_optimization_help">Engedi, hogy az Android optimalizálja a sávbeállításokat, például hozzáadja a 2.4 GHz-es sávot együttműködés vagy országkód-korlátozások miatt.</string>
  <string name="wifi_ap_choose_disabled">Letiltva</string>
  <string name="wifi_ap_choose_G">%s GHz-es sáv</string>
  <string name="wifi_hotspot_acs_channel_2g">Engedélyezett 2.4 GHz-es ACS-csatornák</string>
  <string name="wifi_hotspot_acs_channel_5g">Engedélyezett 5 GHz-es ACS-csatornák</string>
  <string name="wifi_hotspot_acs_channel_6g">Engedélyezett 6 GHz-es ACS-csatornák</string>
  <string name="wifi_hotspot_acs_channel_help">Ebben a sávban az Automatic Channel Selection számára engedélyezett csatornaszámok. Adjon meg vesszővel elválasztott csatornákat vagy tartományokat, például &lt;tt&gt;1,6,11&lt;/tt&gt; vagy &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Hagyja üresen, ha a sáv összes csatornáját engedélyezni szeretné. ACS offload támogatás szükséges; különben az Android figyelmen kívül hagyja ezt a beállítást.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Maximális csatornasávszélesség</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Korlátozza a Soft AP csatornasávszélességét. Az Auto engedi, hogy az Android az eszközön elérhető legnagyobb sávszélességet használja.</string>
  <string name="wifi_channel_width_auto">Automatikus</string>
  <string name="wifi_channel_width_invalid">Érvénytelen</string>
  <string name="wifi_hotspot_access_control_title">Hozzáférés-vezérlés</string>
  <string name="wifi_hotspot_ap_advanced_title">Speciális beállítások</string>
  <string name="wifi_advanced_mac_address_title">MAC-cím</string>
  <string name="wifi_mac_address_persistent_randomization">Tartós véletlenszerűsítés: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Nem tartós véletlenszerűsítés</string>
  <string name="wifi_mac_address_help">Állítsa be az AP BSSID-jét és MAC véletlenszerűsítését. Az Android elutasítja a csupa nulla, multicast és broadcast BSSID-ket. Kifejezett BSSID csak kikapcsolt MAC véletlenszerűsítésnél használatos.</string>
  <string name="wifi_p2p_mac_address_help">Állítsa be az ismétlő által használt P2P eszközcímet. Hagyja üresen, hogy az Android válassza ki a címet.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Tartósan randomizált MAC-cím</string>
  <string name="wifi_hidden_network">Rejtett hálózat</string>
  <string name="wifi_hidden_network_help">Ne sugározza az SSID-t</string>
  <string name="wifi_max_clients">Kliensek maximális száma</string>
  <string name="wifi_max_clients_help">Az AP-hez társítható kliensek maximális száma. Üres értéknél az Android az eszköz vagy a szolgáltató korlátját használja; a korlát feletti klienseket elutasítja.</string>
  <string name="wifi_blocked_list">Blokkolt kliensek listája</string>
  <string name="wifi_blocked_list_help">MAC-címek, amelyek nem társíthatók a Soft AP-hez. Ügyfél kényszerített leválasztásának támogatása szükséges; különben a hotspot nem támogatott konfigurációs hibával nem indulhat el.</string>
  <string name="wifi_client_user_control">Kliens-társítás felhasználói vezérlése</string>
  <string name="wifi_client_user_control_help">Ki: a blokkolt listán kívüli bármely kliens csatlakozhat a megfelelő adatokkal, amíg a hotspot meg nem telik; az engedélyezett lista figyelmen kívül marad. Be: az Android az engedélyezett és blokkolt listákkal fogad el, utasít el vagy kér jóváhagyást. Kliens kényszerített leválasztása szükséges.</string>
  <string name="wifi_allowed_list">Engedélyezett kliensek listája</string>
