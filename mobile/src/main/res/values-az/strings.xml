  <string name="wifi_mac_address_non_persistent_randomization">Daimi olmayan təsadüfiləşdirmə</string>
  <string name="wifi_mac_address_help">AP üçün BSSID və MAC təsadüfiləşdirməsini qurun. Android bütün sıfır, multicast və broadcast BSSID-ləri rədd edir. Açıq BSSID yalnız MAC təsadüfiləşdirməsi söndürüləndə istifadə olunur.</string>
  <string name="wifi_p2p_mac_address_help">Təkrarlayıcının istifadə etdiyi P2P cihaz ünvanını qurun. Android-in ünvan seçməsi üçün boş saxlayın.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Daimi təsadüfi MAC ünvanı</string>
  <string name="wifi_hidden_network">Gizlədilmiş şəbəkə</string>
