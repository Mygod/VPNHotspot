  <string name="wifi_mac_address_persistent_randomization">Aleatorización persistente: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Aleatorización non persistente</string>
  <string name="wifi_mac_address_help">Configura o BSSID e a aleatorización de MAC para o AP. Android rexeita BSSID de todo ceros, multicast e broadcast. Un BSSID explícito só se usa cando a aleatorización de MAC está desactivada.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Enderezo MAC aleatorio persistente</string>
