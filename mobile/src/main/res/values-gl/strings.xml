  <string name="wifi_mac_randomization_persistent">Aleatorización persistente</string>
  <string name="wifi_mac_randomization_persistent_help">Xera un enderezo MAC de AP aleatorio que se conserva por SSID mentres o SSID non cambie.</string>
  <string name="wifi_mac_randomization_non_persistent">Aleatorización non persistente</string>
