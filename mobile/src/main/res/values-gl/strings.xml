  <string name="wifi_hotspot_acs_channel_2g">Canles ACS de 2.4 GHz permitidas</string>
  <string name="wifi_hotspot_acs_channel_5g">Canles ACS de 5 GHz permitidas</string>
  <string name="wifi_hotspot_acs_channel_6g">Canles ACS de 6 GHz permitidas</string>
  <string name="wifi_hotspot_acs_channel_help">Números de canle permitidos para a selección automática de canle nesta banda. Introduce canles ou intervalos separados por comas, como &lt;tt&gt;1,6,11&lt;/tt&gt; ou &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Deixa baleiro para permitir todas as canles da banda. Require compatibilidade con ACS offload; doutro xeito Android ignora este axuste.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Ancho máximo da canle</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Limita o ancho de canle do Soft AP. Auto permite que Android use o ancho máximo posible no dispositivo.</string>
  <string name="wifi_channel_width_auto">Automático</string>
