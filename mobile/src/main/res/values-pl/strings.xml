  <string name="wifi_password">Hasło</string>
  <string name="wifi_password_show">Pokaż hasło</string>
  <string name="wifi_password_hide">Ukryj hasło</string>
  <string name="wifi_password_error_required">Hasło jest wymagane</string>
  <string name="wifi_password_error_length">Hasło musi mieć 8–63 znaki</string>
  <string name="wifi_password_help">Klucz wstępnie udostępniony dla zabezpieczeń osobistych WPA2/WPA3. Hasła przejściowe WPA2-PSK i WPA3-SAE muszą mieć 8–63 znaki.</string>
  <string name="wifi_hotspot_auto_off">Automatycznie wyłącz hotspot</string>
  <string name="wifi_hotspot_auto_off_help">Gdy przez czas wyłączenia nie są podłączone żadne urządzenia: %s</string>
  <string name="wifi_hotspot_timeout">Limit czasu wyłączenia</string>
  <string name="wifi_hotspot_timeout_help">Skonfiguruj czas oczekiwania bez podłączonych urządzeń przed automatycznym wyłączeniem.&lt;br&gt;&lt;br&gt;Domyślnie: %s</string>
  <string name="wifi_hotspot_timeout_default">Domyślnie (%s)</string>
  <string name="wifi_hotspot_ap_band_title">Pasmo AP</string>
  <string name="wifi_hotspot_ap_channel_band_title">Kanał/pasmo AP</string>
  <string name="wifi_hotspot_ap_channel_band_help">Nieobsługiwane pasmo lub kanał może spowodować niepowodzenie uruchomienia hotspotu.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Równoczesny kanał/pasmo AP</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">Dodaje drugą instancję AP, gdy obsługiwana jest współbieżność bridged AP. Nieobsługiwane kombinacje pasma/kanału mogą nie zadziałać przy uruchamianiu hotspotu.</string>
  <string name="wifi_band_optimization">Włącz optymalizację pasma</string>
  <string name="wifi_band_optimization_help">Pozwala Androidowi optymalizować ustawienia pasm, np. dodać pasmo 2.4 GHz ze względu na współistnienie lub ograniczenia kodu kraju.</string>
  <string name="wifi_ap_choose_disabled">Wyłączona</string>
  <string name="wifi_ap_choose_G">Pasmo %s GHz</string>
  <string name="wifi_hotspot_acs_channel_2g">Dozwolone kanały ACS 2.4 GHz</string>
  <string name="wifi_hotspot_acs_channel_5g">Dozwolone kanały ACS 5 GHz</string>
  <string name="wifi_hotspot_acs_channel_6g">Dozwolone kanały ACS 6 GHz</string>
  <string name="wifi_hotspot_acs_channel_help">Numery kanałów dozwolone dla Automatic Channel Selection w tym paśmie. Wpisz kanały lub zakresy oddzielone przecinkami, np. &lt;tt&gt;1,6,11&lt;/tt&gt; albo &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Pozostaw puste, aby zezwolić na wszystkie kanały w paśmie. Wymaga obsługi ACS offload; w przeciwnym razie Android ignoruje to ustawienie.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Maksymalna szerokość kanału</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Ogranicza szerokość kanału Soft AP. Auto pozwala Androidowi użyć maksymalnej szerokości dostępnej na urządzeniu.</string>
  <string name="wifi_channel_width_auto">Automatycznie</string>
  <string name="wifi_channel_width_invalid">Nieprawidłowe</string>
  <string name="wifi_hotspot_access_control_title">Kontrola dostępu</string>
  <string name="wifi_hotspot_ap_advanced_title">Opcje zaawansowane</string>
  <string name="wifi_advanced_mac_address_title">Adres MAC</string>
  <string name="wifi_mac_address_persistent_randomization">Trwała randomizacja: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Nietrwała randomizacja</string>
  <string name="wifi_mac_address_help">Skonfiguruj BSSID i randomizację MAC dla AP. Android odrzuca BSSID z samych zer, multicast i broadcast. Jawny BSSID jest używany tylko wtedy, gdy randomizacja MAC jest wyłączona.</string>
  <string name="wifi_p2p_mac_address_help">Skonfiguruj adres urządzenia P2P używany przez repeater. Pozostaw puste, aby Android wybrał adres.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Trwały losowy adres MAC</string>
  <string name="wifi_hidden_network">Sieć ukryta</string>
  <string name="wifi_hidden_network_help">Nie rozgłaszaj SSID</string>
  <string name="wifi_max_clients">Maksymalna liczba klientów</string>
  <string name="wifi_max_clients_help">Maksymalna liczba klientów, którzy mogą skojarzyć się z AP. Puste pole pozwala Androidowi użyć limitu urządzenia lub operatora; klienci powyżej limitu są odrzucani.</string>
  <string name="wifi_blocked_list">Lista zablokowanych klientów</string>
  <string name="wifi_blocked_list_help">Adresy MAC, które nie mogą skojarzyć się z Soft AP. Wymaga obsługi wymuszonego rozłączania klientów; w przeciwnym razie hotspot może nie uruchomić się z błędem nieobsługiwanej konfiguracji.</string>
  <string name="wifi_client_user_control">Kontrola użytkownika nad kojarzeniem klientów</string>
  <string name="wifi_client_user_control_help">Wyłączone: każdy klient spoza listy zablokowanych może połączyć się z poprawnymi danymi, dopóki hotspot się nie zapełni; lista dozwolonych jest ignorowana. Włączone: Android używa list dozwolonych i zablokowanych do akceptacji, odrzucania lub żądania zatwierdzenia. Wymaga wymuszonego rozłączania klientów.</string>
  <string name="wifi_allowed_list">Lista dozwolonych klientów</string>
  <string name="wifi_client_lists_overlap_error">Adres MAC znajduje się na obu listach klientów</string>
  <string name="wifi_mac_randomization_none">Bez randomizacji</string>
  <string name="wifi_mac_randomization_none_help">Użyj fabrycznego lub jawnie skonfigurowanego adresu MAC AP.</string>
  <string name="wifi_mac_randomization_persistent">Trwała randomizacja</string>
  <string name="wifi_mac_randomization_persistent_help">Generuje losowy adres MAC AP zachowywany dla danego SSID, dopóki SSID pozostaje takie samo.</string>
  <string name="wifi_mac_randomization_non_persistent">Nietrwała randomizacja</string>
  <string name="wifi_mac_randomization_non_persistent_help">Generuje losowy adres MAC AP za każdym razem, gdy AP jest ponownie włączany.</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown">Oportunistyczne wyłączanie w trybie mostu</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown_help">W trybie bridged AP Android może wyłączyć bezczynną instancję AP po bridged timeout: %s</string>
  <string name="wifi_hotspot_timeout_bridged">Limit bezczynności dla instancji mostu</string>
  <string name="wifi_hotspot_timeout_bridged_help">Skonfiguruj czas oczekiwania bezczynnej instancji bridged AP przed oportunistycznym wyłączeniem. Jeśli obie instancje są bezczynne, Android wyłącza instancję o wyższej częstotliwości. Ogólny timeout hotspotu nadal obowiązuje osobno.&lt;br&gt;&lt;br&gt;Domyślnie: %s</string>
  <string name="wifi_ieee_80211ax">Włącz Wi‑Fi 6</string>
  <string name="wifi_ieee_80211ax_help">Włącz 802.11ax, jeśli jest obsługiwane</string>
  <string name="wifi_ieee_80211be">Włącz Wi‑Fi 7</string>
  <string name="wifi_ieee_80211be_help">Włącz 802.11be, jeśli jest obsługiwane</string>
  <string name="wifi_user_config">Skonfigurowane przez użytkownika</string>
  <string name="wifi_vendor_elements">Elementy dostawcy</string>
  <string name="wifi_vendor_elements_help">Elementy informacyjne specyficzne dla dostawcy wysyłane w AP beaconach i odpowiedziach probe. Wpisz po jednym szesnastkowo zakodowanym ciele vendor IE w każdym wierszu, np. &lt;tt&gt;AABBCC01&lt;/tt&gt;. Nie dodawaj identyfikatora elementu &lt;tt&gt;0xDD&lt;/tt&gt; ani bajtu długości.</string>
  <string name="wifi_vendor_data">Dane producenta</string>
  <string name="wifi_vendor_data_help">Surowe dane konfiguracji HAL dostarczone przez dostawcę. Dla każdego wpisu podaj jeden dokument XML &lt;tt&gt;PersistableBundle&lt;/tt&gt; z prefiksem OUI.&lt;br&gt;&lt;br&gt;Przykład: </string>
