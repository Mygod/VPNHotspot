  <string name="wifi_vendor_data_error_incomplete_xml">Niekompletny XML danych producenta dla OUI %1$s</string>
  <string name="wifi_client_isolation">Izolacja klientów</string>
  <string name="wifi_client_isolation_help">Zabroń połączonym klientom komunikacji z innymi połączonymi klientami</string>
