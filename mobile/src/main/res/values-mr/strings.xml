  <string name="wifi_hotspot_ap_channel_band_title">AP चॅनल/बँड</string>
  <string name="wifi_hotspot_ap_channel_band_help">असमर्थित बँड/चॅनलमुळे हॉटस्पॉट सुरू होण्यात अपयश येऊ शकते.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">समवर्ती AP चॅनल/बँड</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">bridged AP concurrency support असेल तेव्हा दुसरी AP instance जोडते. unsupported band/channel combination hotspot start होताना fail होऊ शकतात.</string>
  <string name="wifi_band_optimization">बँड ऑप्टिमायझेशन सक्षम करा</string>
  <string name="wifi_band_optimization_help">सहअस्तित्व किंवा देश-कोड मर्यादांसाठी 2.4 GHz बँड जोडण्यासारखी बँड सेटिंग्ज Android ला ऑप्टिमाइझ करू देते.</string>
  <string name="wifi_ap_choose_disabled">अक्षम</string>
  <string name="wifi_ap_choose_G">%s GHz बँड</string>
  <string name="wifi_hotspot_acs_channel_2g">अनुमत 2.4 GHz ACS चॅनेल</string>
  <string name="wifi_hotspot_acs_channel_5g">अनुमत 5 GHz ACS चॅनेल</string>
  <string name="wifi_hotspot_acs_channel_6g">अनुमत 6 GHz ACS चॅनेल</string>
  <string name="wifi_hotspot_acs_channel_help">या band मध्ये Automatic Channel Selection साठी अनुमत channel numbers. comma-separated channels किंवा ranges द्या, उदा. &lt;tt&gt;1,6,11&lt;/tt&gt; किंवा &lt;tt&gt;36-48,149-161&lt;/tt&gt;. band मधील सर्व channels अनुमत करायचे असल्यास रिकामे ठेवा. ACS offload support आवश्यक आहे; अन्यथा Android हे setting ignore करते.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">कमाल चॅनल बँडविड्थ</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Soft AP चॅनल बँडविड्थ मर्यादित करते. Auto Android ला डिव्हाइसवर शक्य असलेली कमाल बँडविड्थ वापरू देते.</string>
  <string name="wifi_channel_width_auto">स्वयंचलित</string>
