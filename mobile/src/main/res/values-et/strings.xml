  <string name="wifi_mac_randomization_persistent_help">Loo juhuslik AP MAC-aadress, mis säilib SSID kaupa, kuni SSID jääb samaks.</string>
  <string name="wifi_mac_randomization_non_persistent">Mittepüsiv juhuslikustamine</string>
  <string name="wifi_mac_randomization_non_persistent_help">Loo juhuslik AP MAC-aadress iga kord, kui AP uuesti lubatakse.</string>
