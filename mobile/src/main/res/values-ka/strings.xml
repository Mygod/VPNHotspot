  <string name="settings_service_upstream_help">მთავარი ზედა ინტერფეისის regex, რომელიც ქვედა ტრაფიკის ხელახლა მარშრუტიზაციისთვის გამოიყენება. VPN Hotspot-ს თავად უნდა შეეძლოს ამ VPN-ის გამოყენება, რომ იმუშაოს. VPN-ით tethering-ის ჩასახშობად გამოიყენეთ &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; ან სხვა არასწორი regex.</string>
  <string name="settings_upstream_fallback_help">სარეზერვო ზედა ინტერფეისი გამოიყენება, როცა VPN ზოგიერთ მარშრუტს ნაგულისხმევ ქსელზე ტოვებს. სარეზერვოს ასაკრძალად გამოიყენეთ &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; ან სხვა არასწორი regex.</string>
  <string name="settings_service_masquerade_none_summary">არ გადაიწეროს downstream წყაროს მისამართები ან პორტები. ეს შეიძლება უკეთ იმუშაოს dummy VPN-ებთან, როგორიცაა რეკლამის ბლოკერები ან socksifier-ები, მაგრამ ნამდვილ VPN-ებთან არ უნდა გამოიყენოთ.</string>
  <string name="settings_service_masquerade_simple_summary">გადაწეროს downstream წყაროს მისამართები და პორტები აპის საკუთარ routing წესებში.</string>
  <string name="settings_service_masquerade_netd_summary">სთხოვოს Android-ის &lt;tt&gt;netd&lt;/tt&gt;-ს masquerade-ის დამუშავება. Android-მა შეიძლება დაამატოს პლატფორმული დამატებები, როგორიცაა &lt;tt&gt;FTP&lt;/tt&gt;-ის დამუშავება და tethering-ის მრიცხველები, მაგრამ ეს ცუდად ერგება შემთხვევას, როცა tethering აქტივობის ოპერატორისგან დამალვა გჭირდებათ.</string>
  <string name="settings_service_ipv6_mode_system_summary">IPv6 დამუშავება პლატფორმის მარშრუტიზაციის კონფიგურაციას დაუტოვეთ.</string>
  <string name="settings_service_ipv6_mode_block_summary">აღკვეთს IPv6 გაჟონვას ქვედა ინტერფეისებზე.</string>
  <string name="settings_service_ipv6_mode_nat_summary">ანიჭებს დეტერმინისტულ აპის საკუთრებაში არსებულ ULA &lt;tt&gt;/64&lt;/tt&gt;-ს და root daemon-ის მეშვეობით proxy-ს უკეთებს ქვედა IPv6 &lt;tt&gt;TCP&lt;/tt&gt;/&lt;tt&gt;UDP&lt;/tt&gt;-ს plus best-effort &lt;tt&gt;ICMPv6&lt;/tt&gt;. ეს არის მომხმარებლის სივრცის სამუშაო, არა სრული packet NAT, და სხვა IPv6 next-header პროტოკოლებს არ გადაამისამართებს.</string>
  <string name="settings_service_auto_start">სერვისების ავტომატური გაშვება</string>
  <string name="settings_service_auto_start_summary">აღადგინეთ სერვისები, თუ ისინი მუშაობდა მოწყობილობის გადატვირთვამდე ან აპის განახლებამდე.</string>
  <string name="settings_service_repeater_safe_mode">რეპიტერის უსაფრთხო რეჟიმი</string>
  <string name="settings_service_repeater_safe_mode_summary">არ ცვლის სისტემის კონფიგურაციას, მაგრამ შესაძლოა არ იმუშაოს მოკლე ქსელის სახელებთან. არაუსაფრთხო რეჟიმი შესაძლოა არ იმუშაოს თქვენს მოწყობილობაზე და დროებით, აღდგენადი ფორმით გამოუსადეგარი გახადოს ის.</string>
  <string name="settings_service_repeater_safe_mode_warning">მოკლე ქსელის სახელებმა შეიძლება მოითხოვოს უსაფრთხო რეჟიმის გამორთვა.</string>
  <string name="settings_service_temp_hotspot_use_system">სისტემის კონფიგურაციის გამოყენება დროებითი hotspot-ისთვის</string>
  <string name="settings_service_temp_hotspot_use_system_summary">კონფლიქტში შევა სხვა აპებთან, რომლებიც იყენებენ მხოლოდ ლოკალურ hotspot-ს. ასევე უფრო მეტ რესურსს იყენებს ფონში, თუ სისტემურ აპად არ არის დაყენებული.</string>
  <string name="settings_service_temp_hotspot_use_system_summary_api30">კონფლიქტში შევა სხვა აპებთან, რომლებიც იყენებენ მხოლოდ ლოკალურ hotspot-ს. ასევე უფრო მეტ რესურსს იყენებს ფონში, თუ სისტემურ აპად არ არის დაყენებული. დიდი ალბათობით მუშაობს Android 12-ზე ან უფრო ახალზე.</string>
