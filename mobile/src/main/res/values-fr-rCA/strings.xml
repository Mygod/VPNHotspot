  <string name="wifi_hotspot_ap_band_title">Bande PA</string>
  <string name="wifi_hotspot_ap_channel_band_title">Canal/bande du point d’accès</string>
  <string name="wifi_hotspot_ap_channel_band_help">Une bande ou un canal non pris en charge peut empêcher le démarrage du point d’accès.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Canal/bande du point d’accès concurrent</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">Ajoute une deuxième instance AP lorsque la simultanéité AP en pont est prise en charge. Les combinaisons bande/canal non prises en charge peuvent échouer au démarrage du point d’accès.</string>
  <string name="wifi_band_optimization">Activer l’optimisation de bande</string>
  <string name="wifi_band_optimization_help">Permet à Android d’optimiser les paramètres de bande, par exemple en ajoutant la bande 2.4 GHz pour la coexistence ou les restrictions de code pays.</string>
  <string name="wifi_ap_choose_disabled">Désactivés</string>
  <string name="wifi_ap_choose_G">Bande %s GHz</string>
  <string name="wifi_hotspot_acs_channel_2g">Canaux ACS 2.4 GHz autorisés</string>
  <string name="wifi_hotspot_acs_channel_5g">Canaux ACS 5 GHz autorisés</string>
  <string name="wifi_hotspot_acs_channel_6g">Canaux ACS 6 GHz autorisés</string>
  <string name="wifi_hotspot_acs_channel_help">Numéros de canaux autorisés pour la sélection automatique des canaux dans cette bande. Saisissez des canaux ou plages séparés par des virgules, comme &lt;tt&gt;1,6,11&lt;/tt&gt; ou &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Laissez vide pour autoriser tous les canaux de la bande. Nécessite la prise en charge de l’ACS offload ; sinon Android ignore ce paramètre.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Largeur de canal maximale</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Limite la largeur de canal du Soft AP. Auto permet à Android d’utiliser la largeur maximale disponible sur l’appareil.</string>
  <string name="wifi_channel_width_auto">Automatique</string>
  <string name="wifi_channel_width_invalid">Non valide</string>
  <string name="wifi_hotspot_access_control_title">Contrôle d’accès</string>
  <string name="wifi_hotspot_ap_advanced_title">Options avancées</string>
  <string name="wifi_advanced_mac_address_title">Adresse MAC</string>
  <string name="wifi_mac_address_persistent_randomization">Randomisation persistante : %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Randomisation non persistante</string>
  <string name="wifi_mac_address_help">Configurez le BSSID et la randomisation MAC du point d’accès. Android refuse les BSSID tout à zéro, multicast et broadcast. Un BSSID explicite n’est utilisé que lorsque la randomisation MAC est désactivée.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Adresse MAC aléatoire persistante</string>
  <string name="wifi_hidden_network">Réseau masqué</string>
  <string name="wifi_hidden_network_help">Ne pas diffuser le SSID</string>
  <string name="wifi_max_clients">Nombre maximal de clients</string>
  <string name="wifi_max_clients_help">Nombre maximal de clients pouvant s’associer au point d’accès. Si le champ est vide, Android utilise la limite de l’appareil ou de l’opérateur ; les clients au-delà de la limite sont refusés.</string>
  <string name="wifi_blocked_list">Liste des clients bloqués</string>
  <string name="wifi_blocked_list_help">Adresses MAC qui ne peuvent pas s’associer au Soft AP. Nécessite la prise en charge de la déconnexion forcée des clients ; sinon, le point d’accès peut échouer au démarrage avec une erreur de configuration non prise en charge.</string>
  <string name="wifi_client_user_control">Contrôle utilisateur de l’association des clients</string>
  <string name="wifi_client_user_control_help">Désactivé : tout client absent de la liste bloquée peut se connecter avec les bons identifiants jusqu’à ce que le point d’accès soit plein ; la liste autorisée est ignorée. Activé : Android utilise les listes autorisée et bloquée pour accepter, refuser ou demander l’approbation. Nécessite la déconnexion forcée des clients.</string>
  <string name="wifi_allowed_list">Liste des clients autorisés</string>
  <string name="wifi_client_lists_overlap_error">Une adresse MAC existe dans les deux listes de clients</string>
  <string name="wifi_mac_randomization_none">Aucune randomisation</string>
  <string name="wifi_mac_randomization_none_help">Utiliser l’adresse MAC d’usine ou explicitement configurée du point d’accès.</string>
  <string name="wifi_mac_randomization_persistent">Randomisation persistante</string>
  <string name="wifi_mac_randomization_persistent_help">Génère une adresse MAC de point d’accès aléatoire conservée par SSID tant que le SSID reste identique.</string>
  <string name="wifi_mac_randomization_non_persistent">Randomisation non persistante</string>
  <string name="wifi_mac_randomization_non_persistent_help">Génère une adresse MAC de point d’accès aléatoire à chaque réactivation du point d’accès.</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown">Arrêt opportuniste en mode pont</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown_help">En mode AP en pont, Android peut arrêter une instance AP inactive après le délai en pont : %s</string>
  <string name="wifi_hotspot_timeout_bridged">Délai d\'inactivité d\'une instance pontée</string>
  <string name="wifi_hotspot_timeout_bridged_help">Configurez la durée d’attente d’une instance AP en pont inactive avant l’arrêt opportuniste. Si les deux instances sont inactives, Android arrête l’instance de fréquence la plus élevée. Le délai global du point d’accès s’applique toujours séparément.&lt;br&gt;&lt;br&gt;Par défaut : %s</string>
