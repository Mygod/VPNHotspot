  <string name="wifi_hotspot_ap_band_title">Ζώνη ΣΠ</string>
  <string name="wifi_hotspot_ap_channel_band_title">Κανάλι/ζώνη AP</string>
  <string name="wifi_hotspot_ap_channel_band_help">Μη υποστηριζόμενη ζώνη/κανάλι μπορεί να αποτρέψει την εκκίνηση του hotspot.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Ταυτόχρονο κανάλι/ζώνη AP</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">Προσθέτει δεύτερη παρουσία AP όταν υποστηρίζεται ταυτόχρονη λειτουργία bridged AP. Μη υποστηριζόμενοι συνδυασμοί ζώνης/καναλιού μπορεί να αποτύχουν κατά την εκκίνηση του hotspot.</string>
  <string name="wifi_band_optimization">Ενεργοποίηση βελτιστοποίησης ζώνης</string>
  <string name="wifi_band_optimization_help">Επιτρέπει στο Android να βελτιστοποιεί τις ρυθμίσεις ζώνης, όπως την προσθήκη της ζώνης 2.4 GHz για συνύπαρξη ή περιορισμούς κωδικού χώρας.</string>
  <string name="wifi_ap_choose_disabled">Απενεργοποιημένο</string>
  <string name="wifi_ap_choose_G">Ζώνη %s GHz</string>
  <string name="wifi_hotspot_acs_channel_2g">Επιτρεπόμενα κανάλια ACS 2.4 GHz</string>
  <string name="wifi_hotspot_acs_channel_5g">Επιτρεπόμενα κανάλια ACS 5 GHz</string>
  <string name="wifi_hotspot_acs_channel_6g">Επιτρεπόμενα κανάλια ACS 6 GHz</string>
  <string name="wifi_hotspot_acs_channel_help">Αριθμοί καναλιών που επιτρέπονται για Automatic Channel Selection σε αυτή τη ζώνη. Εισαγάγετε κανάλια ή εύρη χωρισμένα με κόμματα, όπως &lt;tt&gt;1,6,11&lt;/tt&gt; ή &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Αφήστε κενό για να επιτρέπονται όλα τα κανάλια της ζώνης. Απαιτεί υποστήριξη ACS offload, αλλιώς το Android αγνοεί αυτή τη ρύθμιση.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Μέγιστο εύρος καναλιού</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Περιορίζει το εύρος καναλιού του Soft AP. Το Auto επιτρέπει στο Android να χρησιμοποιεί το μέγιστο εφικτό εύρος στη συσκευή.</string>
  <string name="wifi_channel_width_auto">Αυτόματα</string>
  <string name="wifi_channel_width_invalid">Μη έγκυρο</string>
  <string name="wifi_hotspot_access_control_title">Έλεγχος πρόσβασης</string>
  <string name="wifi_hotspot_ap_advanced_title">Σύνθετες επιλογές</string>
  <string name="wifi_advanced_mac_address_title">Διεύθυνση MAC</string>
  <string name="wifi_mac_address_persistent_randomization">Μόνιμη τυχαιοποίηση: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Μη μόνιμη τυχαιοποίηση</string>
  <string name="wifi_mac_address_help">Ρυθμίστε το BSSID και την τυχαιοποίηση MAC για το AP. Το Android απορρίπτει BSSID με μόνο μηδενικά, multicast και broadcast. Ένα ρητό BSSID χρησιμοποιείται μόνο όταν η τυχαιοποίηση MAC είναι απενεργοποιημένη.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Μόνιμη τυχαία διεύθυνση MAC</string>
  <string name="wifi_hidden_network">Κρυφό δίκτυο</string>
  <string name="wifi_hidden_network_help">Να μην εκπέμπεται το SSID</string>
  <string name="wifi_max_clients">Μέγιστος αριθμός πελατών</string>
  <string name="wifi_max_clients_help">Μέγιστος αριθμός πελατών που μπορούν να συσχετιστούν με το AP. Αν μείνει κενό, το Android χρησιμοποιεί το όριο της συσκευής ή του παρόχου· οι πελάτες πάνω από το όριο απορρίπτονται.</string>
  <string name="wifi_blocked_list">Λίστα αποκλεισμένων πελατών</string>
  <string name="wifi_blocked_list_help">Διευθύνσεις MAC που δεν μπορούν να συσχετιστούν με το Soft AP. Απαιτεί υποστήριξη αναγκαστικής αποσύνδεσης πελάτη· διαφορετικά το hotspot μπορεί να αποτύχει να ξεκινήσει με σφάλμα μη υποστηριζόμενης διαμόρφωσης.</string>
  <string name="wifi_client_user_control">Έλεγχος χρήστη της συσχέτισης πελατών</string>
  <string name="wifi_client_user_control_help">Ανενεργό: κάθε πελάτης εκτός της λίστας αποκλεισμού μπορεί να συνδεθεί με σωστά διαπιστευτήρια μέχρι να γεμίσει το hotspot· η λίστα επιτρεπόμενων αγνοείται. Ενεργό: το Android χρησιμοποιεί τις λίστες επιτρεπόμενων και αποκλεισμένων για αποδοχή, απόρριψη ή αίτημα έγκρισης. Απαιτεί αναγκαστική αποσύνδεση πελάτη.</string>
  <string name="wifi_allowed_list">Λίστα επιτρεπόμενων πελατών</string>
  <string name="wifi_client_lists_overlap_error">Μια διεύθυνση MAC υπάρχει και στις δύο λίστες πελατών</string>
  <string name="wifi_mac_randomization_none">Χωρίς τυχαιοποίηση</string>
  <string name="wifi_mac_randomization_none_help">Χρήση της εργοστασιακής ή ρητά ρυθμισμένης διεύθυνσης MAC του AP.</string>
  <string name="wifi_mac_randomization_persistent">Μόνιμη τυχαιοποίηση</string>
  <string name="wifi_mac_randomization_persistent_help">Δημιουργεί τυχαία διεύθυνση MAC AP που διατηρείται ανά SSID όσο το SSID παραμένει ίδιο.</string>
  <string name="wifi_mac_randomization_non_persistent">Μη μόνιμη τυχαιοποίηση</string>
  <string name="wifi_mac_randomization_non_persistent_help">Δημιουργεί τυχαία διεύθυνση MAC AP κάθε φορά που το AP ενεργοποιείται ξανά.</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown">Ευκαιριακός τερματισμός σε γεφυρωμένη λειτουργία</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown_help">Σε λειτουργία bridged AP, το Android μπορεί να κλείσει μια αδρανή παρουσία AP μετά το bridged timeout: %s</string>
  <string name="wifi_hotspot_timeout_bridged">Χρονικό όριο αδράνειας για γεφυρωμένη παρουσία</string>
  <string name="wifi_hotspot_timeout_bridged_help">Ρυθμίστε τον χρόνο αναμονής μιας αδρανούς bridged AP παρουσίας πριν από την ευκαιριακή απενεργοποίηση. Αν και οι δύο παρουσίες είναι αδρανείς, το Android κλείνει την παρουσία υψηλότερης συχνότητας. Το συνολικό timeout του hotspot εξακολουθεί να εφαρμόζεται χωριστά.&lt;br&gt;&lt;br&gt;Προεπιλογή: %s</string>
