  <string name="settings_service_masquerade_netd">Υπηρεσία Android Netd</string>
  <string name="settings_service_ipv6_mode">Λειτουργία IPv6</string>
  <string name="settings_service_ipv6_mode_block">Αποκλεισμός</string>
  <string name="settings_service_ipv6_mode_system">Σύστημα</string>
  <string name="settings_service_ipv6_mode_nat">NAT (χώρος χρήστη)</string>
  <string name="settings_service_upstream_help">Regex της κύριας ανοδικής διεπαφής που χρησιμοποιείται για επαναδρομολόγηση καθοδικής κίνησης. Το ίδιο το VPN Hotspot πρέπει να επιτρέπεται να χρησιμοποιεί αυτό το VPN για να λειτουργεί. Χρησιμοποιήστε &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; ή άλλο μη έγκυρο regex για να αποκλείσετε το tethering μέσω VPN.</string>
  <string name="settings_upstream_fallback_help">Η εφεδρική ανοδική διεπαφή χρησιμοποιείται όταν ένα VPN αφήνει ορισμένες διαδρομές στο προεπιλεγμένο δίκτυο. Χρησιμοποιήστε &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; ή άλλο μη έγκυρο regex για να απαγορεύσετε την εφεδρεία.</string>
  <string name="settings_service_masquerade_none_summary">Δεν ξαναγράφει downstream διευθύνσεις ή θύρες προέλευσης. Μπορεί να λειτουργεί καλύτερα με dummy VPN όπως ad blockers, αλλά δεν πρέπει να χρησιμοποιείται με πραγματικά VPN.</string>
  <string name="settings_service_masquerade_simple_summary">Ξαναγράφει downstream διευθύνσεις και θύρες προέλευσης σε κανόνες δρομολόγησης της εφαρμογής.</string>
  <string name="settings_service_masquerade_netd_summary">Ζητά από το Android &lt;tt&gt;netd&lt;/tt&gt; να χειριστεί το masquerade. Το Android μπορεί να προσθέσει platform extras όπως χειρισμό &lt;tt&gt;FTP&lt;/tt&gt; και tethering counters, αλλά δεν είναι καλή επιλογή όταν κρύβεται tethering activity από τον πάροχο.</string>
  <string name="settings_service_ipv6_mode_system_summary">Αφήνει τον χειρισμό IPv6 στη ρύθμιση δρομολόγησης της πλατφόρμας.</string>
  <string name="settings_service_ipv6_mode_block_summary">Αποτρέπει διαρροές IPv6 στις downstream διεπαφές.</string>
  <string name="settings_service_ipv6_mode_nat_summary">Εκχωρεί ένα ντετερμινιστικό ULA &lt;tt&gt;/64&lt;/tt&gt; ιδιοκτησίας της εφαρμογής και κάνει proxy το downstream IPv6 &lt;tt&gt;TCP&lt;/tt&gt;/&lt;tt&gt;UDP&lt;/tt&gt; μαζί με best-effort &lt;tt&gt;ICMPv6&lt;/tt&gt; μέσω του root daemon. Είναι εργασία χώρου χρήστη, όχι πλήρες packet NAT, και δεν προωθεί άλλα IPv6 next-header πρωτόκολλα.</string>
  <string name="settings_service_auto_start">Αυτόματη εκκίνηση υπηρεσιών</string>
  <string name="settings_service_auto_start_summary">Επαναφορά υπηρεσιών αν εκτελούνταν πριν την επανεκκίνηση της συσκευής ή την ενημέρωση της εφαρμογής.</string>
  <string name="settings_service_temp_hotspot_use_system">Χρήση ρύθμισης συστήματος για προσωρινό hotspot</string>
  <string name="settings_service_temp_hotspot_use_system_summary">Θα συγκρουστεί με άλλες εφαρμογές που χρησιμοποιούν hotspot μόνο τοπικά. Χρησιμοποιεί επίσης περισσότερους πόρους στο παρασκήνιο εκτός αν έχει εγκατασταθεί ως εφαρμογή συστήματος.</string>
  <string name="settings_service_temp_hotspot_use_system_summary_api30">Θα συγκρουστεί με άλλες εφαρμογές που χρησιμοποιούν hotspot μόνο τοπικά. Χρησιμοποιεί επίσης περισσότερους πόρους στο παρασκήνιο εκτός αν έχει εγκατασταθεί ως εφαρμογή συστήματος. Πιθανότατα λειτουργεί σε Android 12 ή νεότερο.</string>
  <string name="settings_service_wifi_lock">Διατήρηση Wi‑Fi ενεργού</string>
  <string name="settings_service_wifi_lock_none">Προεπιλογή συστήματος</string>
  <string name="settings_service_wifi_lock_high_perf_v29">Απενεργοποίηση εξοικονόμησης ενέργειας</string>
  <string name="settings_service_wifi_lock_low_latency">Λειτουργία χαμηλής καθυστέρησης</string>
  <string name="settings_service_wifi_lock_none_summary">Χρησιμοποιεί την προεπιλεγμένη συμπεριφορά ισχύος Wi‑Fi του συστήματος για εξοικονόμηση μπαταρίας.</string>
  <string name="settings_service_wifi_lock_high_perf_v29_summary">Μειώνει την καθυστέρηση πακέτων για περιπτώσεις όπως φωνητικές κλήσεις μετά το σβήσιμο της οθόνης. Απαιτεί υποστήριξη υλικού. Σε Android 14 και νεότερο, αυτή η παρωχημένη λειτουργία αντικαθίσταται από τη λειτουργία χαμηλής καθυστέρησης.</string>
  <string name="settings_service_wifi_lock_low_latency_summary">Βελτιστοποιεί χρήσεις ευαίσθητες στην καθυστέρηση, όπως παιχνίδια ή εικονική πραγματικότητα. Μπορεί να μειώσει τη διάρκεια μπαταρίας, τη διεκπεραίωση, τη συχνότητα σάρωσης Wi‑Fi, την ποιότητα περιαγωγής και την ακρίβεια τοποθεσίας. Απαιτεί υποστήριξη υλικού και αυτή η εφαρμογή να εκτελείται στο προσκήνιο με την οθόνη αναμμένη.</string>
  <string name="settings_service_upstream">Ανοδική διεπαφή δικτύου</string>
  <string name="settings_service_upstream_auto">Αυτόματος εντοπισμός VPN συστήματος</string>
  <string name="settings_upstream_fallback">Εφεδρική ανοδική διεπαφή</string>
  <string name="settings_upstream_fallback_auto">Αυτόματος εντοπισμός προεπιλεγμένου δικτύου συστήματος</string>
  <string name="settings_upstream_current_summary">%1$s (τρέχον: %2$s)</string>
  <string name="settings_service_clean">Καθαρισμός/επανεφαρμογή κανόνων δρομολόγησης</string>
  <string name="settings_service_clean_summary">Ενημέρωση των αλλαγμένων ρυθμίσεων στις τρέχουσες ενεργές υπηρεσίες. Μπορεί επίσης να διορθώσει σπάνιες συνθήκες ανταγωνισμού.</string>
  <string name="settings_system_tether_offload">Σύνδεση επιτάχυνσης υλικού</string>
  <string name="settings_system_tether_offload_summary">Συντόμευση στις επιλογές προγραμματιστή του συστήματος. Η απενεργοποίηση συχνά χρειάζεται για VPN tethering μέσω συστημικού tethering, αλλά μπορεί να μειώσει τη διάρκεια μπαταρίας όσο το tethering είναι ενεργό.</string>
