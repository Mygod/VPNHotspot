  <string name="settings_upstream">بالادست</string>
  <string name="settings_downstream">پایین‌دست</string>
  <string name="settings_service_masquerade">حالت ماسک‌کردن IPv4</string>
  <string name="settings_service_masquerade_none">خالی</string>
  <string name="settings_service_masquerade_simple">ساده</string>
