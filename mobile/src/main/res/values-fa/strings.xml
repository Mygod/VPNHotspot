  <string name="wifi_password_help">کلید ازپیش‌اشتراک‌گذاری‌شده برای امنیت شخصی WPA2/WPA3. عبارت‌های گذار WPA2-PSK و WPA3-SAE باید 8–63 نویسه باشند.</string>
  <string name="wifi_hotspot_auto_off">خاموش شدن خودکار نقطه اتصال</string>
  <string name="wifi_hotspot_auto_off_help">وقتی در مدت زمان خاموشی هیچ دستگاهی متصل نیست: %s</string>
  <string name="wifi_hotspot_timeout">مهلت خاموشی</string>
  <string name="wifi_hotspot_timeout_help">زمان انتظار بدون دستگاه متصل را پیش از خاموشی خودکار تنظیم کنید.&lt;br&gt;&lt;br&gt;پیش‌فرض: %s</string>
  <string name="wifi_hotspot_timeout_default">پیش‌فرض (%s)</string>
  <string name="wifi_hotspot_timeout_milliseconds">میلی‌ثانیه</string>
  <string name="wifi_hotspot_ap_band_title">باند AP</string>
  <string name="wifi_hotspot_ap_channel_band_title">کانال/باند AP</string>
  <string name="wifi_hotspot_ap_channel_band_help">باند/کانال پشتیبانی‌نشده می‌تواند باعث شود نقطه اتصال شروع نشود.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">کانال/باند AP هم‌زمان</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">وقتی هم‌زمانی bridged AP پشتیبانی شود، یک نمونه AP دوم اضافه می‌کند. ترکیب‌های پشتیبانی‌نشده باند/کانال ممکن است هنگام شروع hotspot شکست بخورند.</string>
  <string name="wifi_band_optimization">فعال‌سازی بهینه‌سازی باند</string>
  <string name="wifi_band_optimization_help">به Android اجازه می‌دهد تنظیمات باند را بهینه کند، مانند افزودن باند 2.4 GHz برای همزیستی یا محدودیت‌های کد کشور.</string>
  <string name="wifi_ap_choose_disabled">غیرفعال شد</string>
  <string name="wifi_ap_choose_G">باند %s گیگاهرتز</string>
  <string name="wifi_hotspot_acs_channel_2g">کانال‌های ACS مجاز 2.4 GHz</string>
  <string name="wifi_hotspot_acs_channel_5g">کانال‌های ACS مجاز 5 GHz</string>
  <string name="wifi_hotspot_acs_channel_6g">کانال‌های ACS مجاز 6 GHz</string>
  <string name="wifi_hotspot_acs_channel_help">شماره کانال‌های مجاز برای Automatic Channel Selection در این باند. کانال‌ها یا بازه‌های جداشده با ویرگول وارد کنید، مانند &lt;tt&gt;1,6,11&lt;/tt&gt; یا &lt;tt&gt;36-48,149-161&lt;/tt&gt;. برای اجازه دادن به همه کانال‌های باند، خالی بگذارید. به پشتیبانی ACS offload نیاز دارد؛ در غیر این صورت Android این تنظیم را نادیده می‌گیرد.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">بیشینه پهنای باند کانال</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">پهنای باند کانال Soft AP را محدود می‌کند. Auto به Android اجازه می‌دهد بیشترین پهنای باند قابل دستیابی روی دستگاه را استفاده کند.</string>
  <string name="wifi_channel_width_auto">خودکار</string>
  <string name="wifi_channel_width_invalid">نامعتبر</string>
  <string name="wifi_standard_legacy">Wi‑Fi قدیمی</string>
  <string name="wifi_p2p_connection_info_separator">، </string>
  <string name="wifi_hotspot_access_control_title">کنترل دسترسی</string>
  <string name="wifi_hotspot_ap_advanced_title">گزینه‌های پیشرفته</string>
  <string name="wifi_advanced_mac_address_title">مک آدرس</string>
  <string name="wifi_mac_address_persistent_randomization">تصادفی‌سازی پایدار: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">تصادفی‌سازی ناپایدار</string>
  <string name="wifi_mac_address_help">BSSID و تصادفی‌سازی MAC را برای AP پیکربندی کنید. Android شناسه‌های BSSID تمام‌صفر، multicast و broadcast را رد می‌کند. BSSID صریح فقط وقتی استفاده می‌شود که تصادفی‌سازی MAC خاموش باشد.</string>
  <string name="wifi_p2p_mac_address_help">انتخاب کنید که حالت Supplicant یک نشانی MAC پایدار را نگه دارد یا تصادفی‌سازی غیرماندگار درخواست کند.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">نشانی MAC تصادفی پایدار</string>
  <string name="wifi_hidden_network">شبکه پنهان</string>
  <string name="wifi_hidden_network_help">SSID را پخش نکن</string>
  <string name="wifi_max_clients">بیشترین تعداد سرویس‌گیرنده‌ها</string>
  <string name="wifi_max_clients_help">بیشترین تعداد سرویس‌گیرنده‌هایی که می‌توانند با AP مرتبط شوند. اگر خالی باشد Android از محدودیت دستگاه یا اپراتور استفاده می‌کند؛ سرویس‌گیرنده‌های بیش از حد رد می‌شوند.</string>
  <string name="wifi_blocked_list">فهرست سرویس‌گیرنده‌های مسدود</string>
  <string name="wifi_blocked_list_help">نشانی‌های MAC که نمی‌توانند با Soft AP مرتبط شوند. پشتیبانی از قطع اجباری سرویس‌گیرنده لازم است؛ در غیر این صورت نقطه اتصال ممکن است با خطای پیکربندی پشتیبانی‌نشده شروع نشود.</string>
  <string name="wifi_client_user_control">کنترل کاربر بر ارتباط سرویس‌گیرنده</string>
  <string name="wifi_client_user_control_help">خاموش: هر سرویس‌گیرنده‌ای بیرون از فهرست مسدود می‌تواند با اطلاعات درست وصل شود تا نقطه اتصال پر شود؛ فهرست مجاز نادیده گرفته می‌شود. روشن: Android از فهرست‌های مجاز و مسدود برای پذیرش، رد یا درخواست تأیید استفاده می‌کند. قطع اجباری سرویس‌گیرنده لازم است.</string>
  <string name="wifi_allowed_list">فهرست سرویس‌گیرنده‌های مجاز</string>
  <string name="wifi_client_lists_overlap_error">یک نشانی MAC در هر دو فهرست سرویس‌گیرنده وجود دارد</string>
  <string name="wifi_mac_randomization_none">بدون تصادفی‌سازی</string>
  <string name="wifi_mac_randomization_none_help">از نشانی MAC کارخانه‌ای یا صریحاً پیکربندی‌شده AP استفاده کن.</string>
  <string name="wifi_mac_randomization_persistent">تصادفی‌سازی پایدار</string>
  <string name="wifi_mac_randomization_persistent_help">یک نشانی MAC تصادفی برای AP ایجاد می‌کند که تا وقتی SSID همان بماند برای هر SSID نگه داشته می‌شود.</string>
  <string name="wifi_mac_randomization_non_persistent">تصادفی‌سازی ناپایدار</string>
  <string name="wifi_mac_randomization_non_persistent_help">هر بار که AP دوباره فعال می‌شود یک نشانی MAC تصادفی برای AP ایجاد می‌کند.</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown">خاموشی فرصت‌طلبانه در حالت پل</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown_help">در حالت bridged AP، Android می‌تواند یک نمونه AP بیکار را پس از bridged timeout خاموش کند: %s</string>
  <string name="wifi_hotspot_timeout_bridged">مهلت بیکاری برای نمونه پل‌شده</string>
  <string name="wifi_hotspot_timeout_bridged_help">زمان انتظار یک نمونه bridged AP بیکار پیش از خاموشی فرصت‌طلبانه را تنظیم کنید. اگر هر دو نمونه بیکار باشند، Android نمونه با فرکانس بالاتر را خاموش می‌کند. timeout کلی hotspot همچنان جداگانه اعمال می‌شود.&lt;br&gt;&lt;br&gt;پیش‌فرض: %s</string>
  <string name="wifi_ieee_80211ax">فعال‌کردن Wi‑Fi 6</string>
  <string name="wifi_ieee_80211ax_help">اگر پشتیبانی می‌شود 802.11ax را فعال کن</string>
  <string name="wifi_ieee_80211be">فعال‌کردن Wi‑Fi 7</string>
