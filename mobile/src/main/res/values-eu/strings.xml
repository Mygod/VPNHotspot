  <string name="settings_service_upstream_help">Beheranzko trafikoa berriro bideratzeko erabiltzen den goranzko interfaze nagusiaren regex-a. VPN Hotspot berak VPN hori erabiltzeko baimena izan behar du funtzionatzeko. Erabili &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; edo beste regex baliogabe bat VPN bidezko partekatzea ezabatzeko.</string>
  <string name="settings_upstream_fallback_help">Ordezko goranzkoa VPN batek ibilbide batzuk sare lehenetsian uzten dituenean erabiltzen da. Erabili &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; edo beste regex baliogabe bat ordezkoa debekatzeko.</string>
  <string name="settings_service_masquerade_none_summary">Ez berridatzi downstream jatorri-helbiderik edo porturik. Dummy VPNekin, hala nola iragarki-blokeatzaileekin, hobeto ibil daiteke, baina ez da benetako VPNekin erabili behar.</string>
  <string name="settings_service_masquerade_simple_summary">Berridatzi downstream jatorri-helbideak eta portuak aplikazioaren routing arauetan.</string>
  <string name="settings_service_masquerade_netd_summary">Eskatu Android &lt;tt&gt;netd&lt;/tt&gt;-ri masquerade kudeatzeko. Android-ek platform extras gehi ditzake, hala nola &lt;tt&gt;FTP&lt;/tt&gt; handling eta tethering counters, baina ez da egokia tethering activity operadoreari ezkutatzeko.</string>
  <string name="settings_service_ipv6_mode_system_summary">IPv6 kudeaketa plataformaren bideratze-konfigurazioaren esku uzten du.</string>
  <string name="settings_service_ipv6_mode_block_summary">IPv6 ihesak saihesten ditu downstream interfazeetan.</string>
  <string name="settings_service_ipv6_mode_nat_summary">Aplikazioaren ULA &lt;tt&gt;/64&lt;/tt&gt; determinista esleitzen du eta root daemonaren bidez downstream IPv6 &lt;tt&gt;TCP&lt;/tt&gt;/&lt;tt&gt;UDP&lt;/tt&gt; eta best-effort &lt;tt&gt;ICMPv6&lt;/tt&gt; proxya egiten du. Erabiltzaile-espazioko lana da, ez packet NAT osoa, eta ez ditu beste IPv6 next-header protokoloak birbidaltzen.</string>
  <string name="settings_service_auto_start">Abiarazi zerbitzuak automatikoki</string>
  <string name="settings_service_auto_start_summary">Leheneratu zerbitzuak gailua berrabiarazi edo aplikazioa eguneratu aurretik martxan bazeuden.</string>
  <string name="settings_service_temp_hotspot_use_system">Erabili sistemaren konfigurazioa aldi baterako hotspot-erako</string>
  <string name="settings_service_temp_hotspot_use_system_summary">Hotspot lokal soila erabiltzen duten beste aplikazioekin gatazkan egongo da. Atzeko planoan baliabide gehiago ere erabiltzen ditu, sistemako aplikazio gisa instalatuta ez badago.</string>
  <string name="settings_service_temp_hotspot_use_system_summary_api30">Hotspot lokal soila erabiltzen duten beste aplikazioekin gatazkan egongo da. Atzeko planoan baliabide gehiago ere erabiltzen ditu, sistemako aplikazio gisa instalatuta ez badago. Seguruenik Android 12 edo berriagoan funtzionatuko du.</string>
  <string name="settings_service_wifi_lock">Mantendu Wi‑Fi aktibo</string>
