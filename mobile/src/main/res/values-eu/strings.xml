  <string name="wifi_hotspot_ap_band_title">AP banda</string>
  <string name="wifi_hotspot_ap_channel_band_title">AP kanala/banda</string>
  <string name="wifi_hotspot_ap_channel_band_help">Onartu gabeko banda edo kanal batek hotspotaren abioa hutsaraz dezake.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Aldi bereko AP kanala/banda</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">Bigarren AP instantzia bat gehitzen du bridged AP concurrency onartzen denean. Onartu gabeko banda/kanal konbinazioek huts egin dezakete hotspot-a abiaraztean.</string>
  <string name="wifi_band_optimization">Gaitu bandaren optimizazioa</string>
  <string name="wifi_band_optimization_help">Androidek banda-ezarpenak optimizatzea ahalbidetzen du, adibidez 2.4 GHz banda gehitzea elkarbizitzarako edo herrialde-kodearen murrizketengatik.</string>
  <string name="wifi_ap_choose_disabled">Desgaituta</string>
  <string name="wifi_ap_choose_G">%s GHz banda</string>
  <string name="wifi_hotspot_acs_channel_2g">Baimendutako 2.4 GHz ACS kanalak</string>
  <string name="wifi_hotspot_acs_channel_5g">Baimendutako 5 GHz ACS kanalak</string>
  <string name="wifi_hotspot_acs_channel_6g">Baimendutako 6 GHz ACS kanalak</string>
  <string name="wifi_hotspot_acs_channel_help">Banda honetan Automatic Channel Selection-erako baimendutako kanal-zenbakiak. Sartu komaz bereizitako kanalak edo tarteak, adibidez &lt;tt&gt;1,6,11&lt;/tt&gt; edo &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Utzi hutsik bandako kanal guztiak baimentzeko. ACS offload euskarria behar du; bestela Android-ek ezarpen hau ez ikusiarena egiten du.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Kanalaren gehieneko banda-zabalera</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Soft AP kanalaren banda-zabalera mugatzen du. Auto aukerak Androidek gailuan lor daitekeen gehieneko zabalera erabiltzea uzten du.</string>
  <string name="wifi_channel_width_auto">Automatikoa</string>
  <string name="wifi_channel_width_invalid">Baliogabea</string>
  <string name="wifi_hotspot_access_control_title">Sarbide-kontrola</string>
  <string name="wifi_hotspot_ap_advanced_title">Aukera aurreratuak</string>
  <string name="wifi_advanced_mac_address_title">MAC helbidea</string>
  <string name="wifi_mac_address_persistent_randomization">Ausazkotze iraunkorra: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Ausazkotze ez-iraunkorra</string>
  <string name="wifi_mac_address_help">Konfiguratu APren BSSIDa eta MAC ausazkotzea. Androidek zeroz osatutako, multicast eta broadcast BSSIDak baztertzen ditu. BSSID esplizitua MAC ausazkotzea desaktibatuta dagoenean bakarrik erabiltzen da.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">MAC helbide ausazko iraunkorra</string>
  <string name="wifi_hidden_network">Sare ezkutua</string>
  <string name="wifi_hidden_network_help">Ez zabaldu SSIDa</string>
  <string name="wifi_max_clients">Gehieneko bezero kopurua</string>
  <string name="wifi_max_clients_help">AParekin asoziatu daitezkeen bezeroen gehieneko kopurua. Hutsik utzita, Androidek gailuaren edo operadorearen muga erabiltzen du; mugatik gorako bezeroak baztertzen dira.</string>
  <string name="wifi_blocked_list">Blokeatutako bezeroen zerrenda</string>
  <string name="wifi_blocked_list_help">Soft AParekin asoziatu ezin diren MAC helbideak. Bezeroa behartuta deskonektatzeko euskarria behar du; bestela, hotspotak konfigurazio ez-onartuaren errorearekin huts egin dezake abioan.</string>
  <string name="wifi_client_user_control">Bezeroen asoziazioaren erabiltzaile-kontrola</string>
  <string name="wifi_client_user_control_help">Desaktibatuta: blokeatutako zerrendatik kanpoko edozein bezero kredentzial egokiekin konekta daiteke hotspota bete arte; baimendutako zerrenda ez da kontuan hartzen. Aktibatuta: Androidek baimendutako eta blokeatutako zerrendak erabiltzen ditu onartzeko, baztertzeko edo onarpena eskatzeko. Bezeroa behartuta deskonektatzea behar du.</string>
  <string name="wifi_allowed_list">Baimendutako bezeroen zerrenda</string>
  <string name="wifi_client_lists_overlap_error">MAC helbide bat bi bezero-zerrendetan dago</string>
  <string name="wifi_mac_randomization_none">Ausazkotzerik ez</string>
  <string name="wifi_mac_randomization_none_help">Erabili fabrikako edo esplizituki konfiguratutako AP MAC helbidea.</string>
  <string name="wifi_mac_randomization_persistent">Ausazkotze iraunkorra</string>
  <string name="wifi_mac_randomization_persistent_help">Sortu ausazko AP MAC helbide bat SSID bakoitzerako gordetzen dena SSIDa berdin mantentzen den bitartean.</string>
  <string name="wifi_mac_randomization_non_persistent">Ausazkotze ez-iraunkorra</string>
  <string name="wifi_mac_randomization_non_persistent_help">Sortu ausazko AP MAC helbide bat APa berriro gaitzen den bakoitzean.</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown">Zubi moduko itzaltze oportunista</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown_help">Bridged AP moduan, Android-ek geldirik dagoen AP instantzia bat itzal dezake bridged timeout-aren ondoren: %s</string>
  <string name="wifi_hotspot_timeout_bridged">Zubi instantzia baten inaktibitate-denbora</string>
  <string name="wifi_hotspot_timeout_bridged_help">Konfiguratu geldirik dagoen bridged AP instantzia batek itzaltze oportunistaren aurretik zenbat itxaroten duen. Bi instantziak geldirik badaude, Android-ek maiztasun handiagoko instantzia itzaltzen du. Hotspot timeout orokorra bereiz aplikatzen jarraitzen du.&lt;br&gt;&lt;br&gt;Lehenetsia: %s</string>
