  <string name="wifi_client_lists_overlap_error">n MAC-adres bestaan in albei klientlyste</string>
  <string name="wifi_mac_randomization_none">Geen randomisering</string>
  <string name="wifi_mac_randomization_none_help">Gebruik die fabriek- of eksplisiet ingestelde AP-MAC-adres.</string>
  <string name="wifi_mac_randomization_persistent">Aanhoudende randomisering</string>
  <string name="wifi_mac_randomization_persistent_help">Genereer ’n gerandomiseerde AP-MAC-adres wat per SSID behou word terwyl die SSID dieselfde bly.</string>
  <string name="wifi_mac_randomization_non_persistent">Nie-aanhoudende randomisering</string>
  <string name="wifi_mac_randomization_non_persistent_help">Genereer ’n gerandomiseerde AP-MAC-adres elke keer wanneer die AP weer geaktiveer word.</string>
