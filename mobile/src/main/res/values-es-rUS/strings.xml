  <string name="wifi_hotspot_ap_channel_band_help">Una banda o canal no compatible puede hacer que el hotspot no se inicie.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Canal/banda de AP concurrente</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">Agrega una segunda instancia de AP cuando se admite la concurrencia de AP en puente. Las combinaciones de banda/canal no admitidas pueden fallar al iniciar el hotspot.</string>
  <string name="wifi_band_optimization">Activar optimización de banda</string>
  <string name="wifi_band_optimization_help">Permite que Android optimice la configuración de banda, como agregar la banda de 2.4 GHz por coexistencia o restricciones de código de país.</string>
  <string name="wifi_ap_choose_disabled">Inhabilitada</string>
