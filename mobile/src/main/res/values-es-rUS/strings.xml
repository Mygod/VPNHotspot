  <string name="wifi_client_lists_overlap_error">Una dirección MAC existe en ambas listas de clientes</string>
  <string name="wifi_mac_randomization_none">Sin aleatorización</string>
  <string name="wifi_mac_randomization_none_help">Usa la dirección MAC de AP de fábrica o configurada explícitamente.</string>
  <string name="wifi_mac_randomization_persistent">Aleatorización persistente</string>
  <string name="wifi_mac_randomization_persistent_help">Genera una dirección MAC de AP aleatoria que se conserva por SSID mientras el SSID no cambie.</string>
  <string name="wifi_mac_randomization_non_persistent">Aleatorización no persistente</string>
  <string name="wifi_mac_randomization_non_persistent_help">Genera una dirección MAC de AP aleatoria cada vez que se vuelve a activar el AP.</string>
