  <string name="wifi_mac_address_persistent_randomization">Trajna naključnost: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Netrajna naključnost</string>
  <string name="wifi_mac_address_help">Nastavite BSSID in naključnost MAC za AP. Android zavrne BSSID iz samih ničel, multicast in broadcast. Izrecni BSSID se uporabi samo, ko je naključnost MAC izklopljena.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Trajni naključni naslov MAC</string>
  <string name="wifi_hidden_network">Skrito omrežje</string>
  <string name="wifi_hidden_network_help">Ne oddajaj SSID</string>
  <string name="wifi_max_clients">Največje število odjemalcev</string>
  <string name="wifi_max_clients_help">Največje število odjemalcev, ki se lahko povežejo z AP. Če je prazno, Android uporabi omejitev naprave ali operaterja; odjemalci nad omejitvijo so zavrnjeni.</string>
  <string name="wifi_blocked_list">Seznam blokiranih odjemalcev</string>
  <string name="wifi_blocked_list_help">Naslovi MAC, ki se ne morejo povezati s Soft AP. Zahteva podporo za prisilno prekinitev povezave odjemalca; sicer se dostopna točka morda ne zažene z napako nepodprte konfiguracije.</string>
  <string name="wifi_client_user_control">Uporabniški nadzor povezovanja odjemalcev</string>
  <string name="wifi_client_user_control_help">Izklopljeno: vsak odjemalec zunaj seznama blokiranih se lahko poveže s pravilnimi poverilnicami, dokler se dostopna točka ne zapolni; seznam dovoljenih se prezre. Vklopljeno: Android uporablja seznama dovoljenih in blokiranih za sprejem, zavrnitev ali zahtevo po odobritvi. Zahteva prisilno prekinitev povezave odjemalca.</string>
  <string name="wifi_allowed_list">Seznam dovoljenih odjemalcev</string>
  <string name="wifi_client_lists_overlap_error">Naslov MAC je na obeh seznamih odjemalcev</string>
  <string name="wifi_mac_randomization_none">Brez naključnosti</string>
  <string name="wifi_mac_randomization_none_help">Uporabi tovarniški ali izrecno nastavljen naslov MAC AP.</string>
  <string name="wifi_mac_randomization_persistent">Trajna naključnost</string>
  <string name="wifi_mac_randomization_persistent_help">Ustvari naključni naslov MAC AP, ki se ohrani za posamezni SSID, dokler SSID ostane enak.</string>
  <string name="wifi_mac_randomization_non_persistent">Netrajna naključnost</string>
  <string name="wifi_mac_randomization_non_persistent_help">Ustvari naključni naslov MAC AP vsakič, ko je AP znova omogočen.</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown">Oportunistični izklop v načinu mostu</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown_help">V načinu bridged AP lahko Android izklopi nedejavno instanco AP po bridged timeout: %s</string>
  <string name="wifi_hotspot_timeout_bridged">Časovna omejitev nedejavnosti za premoščeno instanco</string>
  <string name="wifi_hotspot_timeout_bridged_help">Nastavite, koliko časa nedejavna instanca bridged AP čaka pred oportunističnim izklopom. Če sta obe instanci nedejavni, Android izklopi instanco z višjo frekvenco. Skupni timeout dostopne točke še vedno velja ločeno.&lt;br&gt;&lt;br&gt;Privzeto: %s</string>
