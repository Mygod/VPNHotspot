  <string name="wifi_mac_address_persistent_randomization">Trajna randomizacija: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Netrajna randomizacija</string>
  <string name="wifi_mac_address_help">Podesite BSSID i MAC randomizaciju za AP. Android odbija BSSID sa svim nulama, multicast i broadcast BSSID. Izričit BSSID se koristi samo kada je MAC randomizacija isključena.</string>
  <string name="wifi_p2p_mac_address_help">Podesite adresu P2P uređaja koju koristi repetitor. Ostavite prazno da Android izabere adresu.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Trajna nasumična MAC adresa</string>
  <string name="wifi_hidden_network">Skrivena mreža</string>
  <string name="wifi_hidden_network_help">Ne emituje SSID</string>
  <string name="wifi_max_clients">Maksimalan broj klijenata</string>
  <string name="wifi_max_clients_help">Maksimalan broj klijenata koji mogu da se povežu sa AP-om. Ako je prazno, Android koristi ograničenje uređaja ili operatera; klijenti preko ograničenja se odbijaju.</string>
  <string name="wifi_blocked_list">Lista blokiranih klijenata</string>
  <string name="wifi_blocked_list_help">MAC adrese koje ne mogu da se povežu sa Soft AP-om. Zahteva podršku za prinudno prekidanje veze klijenta; inače hotspot može da se ne pokrene uz grešku nepodržane konfiguracije.</string>
  <string name="wifi_client_user_control">Korisnička kontrola povezivanja klijenata</string>
  <string name="wifi_client_user_control_help">Isključeno: svaki klijent van blokirane liste može da se poveže ispravnim podacima dok se hotspot ne popuni; dozvoljena lista se ignoriše. Uključeno: Android koristi dozvoljenu i blokiranu listu da prihvati, odbije ili zatraži odobrenje. Zahteva prinudno prekidanje veze klijenta.</string>
