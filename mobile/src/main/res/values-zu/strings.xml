  <string name="wifi_hotspot_timeout">Isikhathi sokuphela sokuvala</string>
  <string name="wifi_hotspot_timeout_help">Lungiselela isikhathi sokulinda ngaphandle kwamadivayisi axhunyiwe ngaphambi kokuvala okuzenzakalelayo.&lt;br&gt;&lt;br&gt;Okuzenzakalelayo: %s</string>
  <string name="wifi_hotspot_timeout_default">Okuzenzakalelayo (%s)</string>
  <string name="wifi_hotspot_ap_band_title">I-AP Band</string>
  <string name="wifi_hotspot_ap_channel_band_title">Ishaneli/ibhendi ye-AP</string>
  <string name="wifi_hotspot_ap_channel_band_help">Ibhendi/ishaneli engasekelwa ingenza i-hotspot yehluleke ukuqala.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Ishaneli/ibhendi ye-AP ngesikhathi esisodwa</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">Yengeza i-AP instance yesibili uma i-bridged AP concurrency isekelwa. Ama-band/channel combination angasekelwa angase fail uma hotspot iqala.</string>
  <string name="wifi_band_optimization">Vumela ukulungiselelwa kwebhendi</string>
  <string name="wifi_band_optimization_help">Ivumela i-Android ukuthi ilungiselele izilungiselelo zebhendi, njengokwengeza ibhendi ye-2.4 GHz ngenxa yokusebenzisana noma imikhawulo yekhodi yezwe.</string>
  <string name="wifi_ap_choose_disabled">Akusebenzi</string>
  <string name="wifi_ap_choose_G">Ibhendi ye-%s GHz</string>
  <string name="wifi_hotspot_acs_channel_2g">Iziteshi ze-ACS 2.4 GHz ezivunyelwe</string>
  <string name="wifi_hotspot_acs_channel_5g">Iziteshi ze-ACS 5 GHz ezivunyelwe</string>
  <string name="wifi_hotspot_acs_channel_6g">Iziteshi ze-ACS 6 GHz ezivunyelwe</string>
  <string name="wifi_hotspot_acs_channel_help">Izinombolo ze-channel ezivunyelwe ku-Automatic Channel Selection kule band. Faka channels noma ranges ezihlukaniswe nge-comma, njenge &lt;tt&gt;1,6,11&lt;/tt&gt; noma &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Shiya kungenalutho ukuze kuvunyelwe wonke ama-channels ku-band. Kudinga ACS offload support; uma kungenjalo Android iyayiziba le setting.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Ububanzi obukhulu beshaneli</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Ikhawulela ububanzi beshaneli ye-Soft AP. Auto ivumela i-Android ukuthi isebenzise ububanzi obukhulu obungenzeka kudivayisi.</string>
  <string name="wifi_channel_width_auto">Okuzenzakalelayo</string>
  <string name="wifi_channel_width_invalid">Ayivumelekile</string>
  <string name="wifi_hotspot_access_control_title">Ukulawula ukufinyelela</string>
  <string name="wifi_hotspot_ap_advanced_title">Izinketho ezithuthukile</string>
  <string name="wifi_advanced_mac_address_title">Ikheli le-MAC</string>
  <string name="wifi_mac_address_persistent_randomization">Ukungahleliwe okuqhubekayo: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Ukungahleliwe okungaqhubeki</string>
  <string name="wifi_mac_address_help">Lungiselela i-BSSID nokungahleliwe kwe-MAC kwe-AP. Android iyenqaba ama-BSSID angamaziro wonke, multicast ne-broadcast. I-BSSID ecacisiwe isetshenziswa kuphela uma ukungahleliwe kwe-MAC kuvaliwe.</string>
  <string name="wifi_p2p_mac_address_help">Lungiselela ikheli ledivayisi ye-P2P elisetshenziswa isiphindi. Shiya kungenalutho ukuze Android ikhethe ikheli.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Ikheli le-MAC elenziwe ngokungahleliwe elihlala njalo</string>
  <string name="wifi_hidden_network">Inethiwekhi efihliwe</string>
  <string name="wifi_hidden_network_help">Ungasakazi i-SSID</string>
  <string name="wifi_max_clients">Inani elikhulu lamaklayenti</string>
  <string name="wifi_max_clients_help">Inani elikhulu lamaklayenti angaxhunyaniswa ne-AP. Uma kungenalutho, Android isebenzisa umkhawulo wedivayisi noma wenkampani yenethiwekhi; amaklayenti angaphezu komkhawulo ayenqatshwa.</string>
  <string name="wifi_blocked_list">Uhlu lwamaklayenti avinjiwe</string>
  <string name="wifi_blocked_list_help">Amakheli e-MAC angeke axhunyaniswe ne-Soft AP. Kudinga ukusekelwa kokuphoqa ukunqamula iklayenti; kungenjalo i-hotspot ingase yehluleke ukuqala ngephutha lokulungiselela elingasekelwa.</string>
  <string name="wifi_client_user_control">Ukulawulwa ngumsebenzisi kokuxhunywa kwamaklayenti</string>
  <string name="wifi_client_user_control_help">Kuvaliwe: noma yiliphi iklayenti elingaphandle kohlu oluvinjiwe lingaxhuma ngemininingwane efanele kuze kugcwale i-hotspot; uhlu oluvunyelwe alunakwa. Kuvuliwe: Android isebenzisa uhlu oluvunyelwe noluvinjiwe ukwamukela, ukwenqaba noma ukucela ukuvunyelwa. Kudinga ukuphoqa ukunqamula iklayenti.</string>
  <string name="wifi_allowed_list">Uhlu lwamaklayenti avunyelwe</string>
  <string name="wifi_client_lists_overlap_error">Ikheli le-MAC likhona kuzo zombili izinhlu zamaklayenti</string>
  <string name="wifi_mac_randomization_none">Akukho ukungahleliwe</string>
  <string name="wifi_mac_randomization_none_help">Sebenzisa ikheli le-AP MAC lasefekthri noma elilungiselelwe ngokusobala.</string>
  <string name="wifi_mac_randomization_persistent">Ukungahleliwe okuqhubekayo</string>
  <string name="wifi_mac_randomization_persistent_help">Kwakha ikheli le-AP MAC elingahleliwe eligcinwa nge-SSID ngayinye inqobo nje uma i-SSID isafana.</string>
  <string name="wifi_mac_randomization_non_persistent">Ukungahleliwe okungaqhubeki</string>
  <string name="wifi_mac_randomization_non_persistent_help">Kwakha ikheli le-AP MAC elingahleliwe njalo lapho i-AP ivulwa kabusha.</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown">Ukuvala okuthatha ithuba kumodi yebhuloho</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown_help">Ku-bridged AP mode, Android ingavala idle AP instance ngemva kwe-bridged timeout: %s</string>
  <string name="wifi_hotspot_timeout_bridged">Isikhathi sokuphela sokungasebenzi se-instance yebhuloho</string>
  <string name="wifi_hotspot_timeout_bridged_help">Configure isikhathi idle bridged AP instance esilindayo ngaphambi kwe-opportunistic shutdown. Uma ama-instances womabili idle, Android ivala instance ene-frequency ephezulu. overall hotspot timeout iyaqhubeka isebenza ngokuhlukile.&lt;br&gt;&lt;br&gt;Default: %s</string>
