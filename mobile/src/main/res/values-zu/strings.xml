  <string name="wifi_password_help">Ukhiye owabelwe kusengaphambili wokuphepha komuntu siqu kwe-WPA2/WPA3. Ama-passphrase e-WPA2-PSK ne-WPA3-SAE transition kufanele abe yizinhlamvu ezingu-8–63.</string>
  <string name="wifi_hotspot_auto_off">Vala ama-hotspot ngokuzenzakalela</string>
