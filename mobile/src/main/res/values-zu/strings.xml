  <string name="settings_service_upstream_help">I-regex yesixhumi esiyinhloko esiya phezulu esetshenziswa uku-reroute traffic esezansi. I-VPN Hotspot ngokwayo kufanele ivunyelwe ukusebenzisa leyo VPN ukuze isebenze. Sebenzisa &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt;, noma enye regex engavumelekile ukucindezela i-tethering nge-VPN.</string>
  <string name="settings_upstream_fallback_help">I-fallback upstream isetshenziswa lapho i-VPN ishiya amanye ama-route kunethiwekhi ezenzakalelayo. Sebenzisa &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt;, noma enye regex engavumelekile ukuvimba i-fallback.</string>
  <string name="settings_service_masquerade_none_summary">Ungaphindi ubhale amakheli omthombo noma ama-port e-downstream. Lokhu kungase kusebenze kangcono nama-dummy VPN afana nama-ad blocker noma ama-socksifier, kodwa akufanele kusetshenziswe nama-VPN angempela.</string>
  <string name="settings_service_masquerade_simple_summary">Phinda ubhale amakheli omthombo nama-port e-downstream emithethweni ye-routing ephethwe uhlelo lokusebenza.</string>
  <string name="settings_service_masquerade_netd_summary">Cela i-Android &lt;tt&gt;netd&lt;/tt&gt; iphathise i-masquerade. I-Android ingangeza izinto ze-platform ezifana nokuphathwa kwe-&lt;tt&gt;FTP&lt;/tt&gt; nama-tethering counters, kodwa lokhu akulungile uma umsebenzi we-tethering kufanele ufihlwe ku-opharetha.</string>
  <string name="settings_service_ipv6_mode_system_summary">Shiya ukuphathwa kwe-IPv6 ekusethweni kwe-routing kwepulatifomu.</string>
  <string name="settings_service_ipv6_mode_block_summary">Vimbela ukuvuza kwe-IPv6 ezixhumanisini ze-downstream.</string>
  <string name="settings_service_ipv6_mode_nat_summary">Yabela i-ULA &lt;tt&gt;/64&lt;/tt&gt; enqunyiwe ephethwe uhlelo lokusebenza futhi i-proxy i-IPv6 ye-downstream &lt;tt&gt;TCP&lt;/tt&gt;/&lt;tt&gt;UDP&lt;/tt&gt; kanye ne-best-effort &lt;tt&gt;ICMPv6&lt;/tt&gt; nge-root daemon. Lo ngumsebenzi we-userspace, akuyona i-packet NAT ephelele, futhi ayidlulisi amanye ama-IPv6 next-header protocols.</string>
  <string name="settings_service_auto_start">Qalisa amasevisi ngokuzenzakalela</string>
  <string name="settings_service_auto_start_summary">Buyisela amasevisi uma ayesebenza ngaphambi kokuthi idivayisi iqale kabusha noma i-app ibuyekezwe.</string>
  <string name="settings_service_repeater_safe_mode">Imodi ephephile ye-repeater</string>
  <string name="settings_service_repeater_safe_mode_summary">Ayenzi zinguquko ku-system configuration yakho, kodwa ingase ingasebenzi namagama enethiwekhi amafushane. Imodi engaphephile ingase ingasebenzi kudivayisi yakho futhi ingayenza ingasebenziseki okwesikhashana ngendlela engalungiseka.</string>
  <string name="settings_service_repeater_safe_mode_warning">Amagama enethiwekhi amafushane angadinga ukuvala imodi ephephile.</string>
  <string name="settings_service_temp_hotspot_use_system">Sebenzisa system configuration ye-hotspot yesikhashana</string>
  <string name="settings_service_temp_hotspot_use_system_summary">Izongqubuzana namanye ama-app asebenzisa local only hotspot. Isebenzisa nezinsiza eziningi ngemuva ngaphandle uma ifakwe njenge-system app.</string>
  <string name="settings_service_temp_hotspot_use_system_summary_api30">Izongqubuzana namanye ama-app asebenzisa local only hotspot. Isebenzisa nezinsiza eziningi ngemuva ngaphandle uma ifakwe njenge-system app. Cishe isebenza ku-Android 12 noma entsha.</string>
  <string name="settings_service_wifi_lock">Gcina i-Wi‑Fi iphila</string>
  <string name="settings_service_wifi_lock_none">Okuzenzakalelayo kwesistimu</string>
  <string name="settings_service_wifi_lock_high_perf_v29">Cisha ukonga amandla</string>
  <string name="settings_service_wifi_lock_low_latency">Imodi yokubambezeleka okuphansi</string>
  <string name="settings_service_wifi_lock_none_summary">Sebenzisa ukuziphatha kwamandla kwe-Wi‑Fi okuzenzakalelayo kwesistimu ukuze wonge ibhethri.</string>
  <string name="settings_service_wifi_lock_high_perf_v29_summary">Yehlisa packet latency ezimweni ezifana namakholi ezwi ngemva kokucima kwesikrini. Kudinga hardware support. Ku-Android 14 nakamuva, le deprecated mode ithathelwa indawo yi-low latency mode.</string>
  <string name="settings_service_wifi_lock_low_latency_summary">Ilungiselela ukusetshenziswa oku-latency-sensitive njengokudlala noma virtual reality. Inganciphisa battery life, throughput, Wi‑Fi scan frequency, roaming quality kanye location accuracy. Kudinga hardware support futhi le app isebenze ku-foreground ngesikrini sivuliwe.</string>
  <string name="settings_service_upstream">Isixhumi senethiwekhi esiya phezulu</string>
  <string name="settings_service_upstream_auto">Thola i-VPN yesistimu ngokuzenzakalela</string>
  <string name="settings_upstream_fallback">Isixhumi esiya phezulu sokubuyela emuva</string>
  <string name="settings_upstream_fallback_auto">Thola inethiwekhi ezenzakalelayo yesistimu ngokuzenzakalela</string>
  <string name="settings_upstream_current_summary">%1$s (okwamanje: %2$s)</string>
  <string name="settings_service_clean">Hlanza/sebenzisa kabusha imithetho yokurutha</string>
  <string name="settings_service_clean_summary">Buyekeza settings ezishintshiwe kumasevisi asebenzayo manje. Ingaphinde ilungise race condition ezingavamile.</string>
  <string name="settings_system_tether_offload">I-Tethering hardware acceleration</string>
  <string name="settings_system_tether_offload_summary">Shortcut kuya ku-system Developer options. Ukuvala lokhu kuvame ukudingeka ku-VPN tethering phezu kwe-system tethering, kodwa kunganciphisa battery life ngenkathi tethering isebenza.</string>
