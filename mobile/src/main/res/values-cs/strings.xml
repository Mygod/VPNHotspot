  <string name="wifi_password_help">Předsdílený klíč pro osobní zabezpečení WPA2/WPA3. Přechodové heslové fráze WPA2-PSK a WPA3-SAE musí mít 8–63 znaků.</string>
  <string name="wifi_hotspot_auto_off">Hotspot automaticky vypínat</string>
  <string name="wifi_hotspot_auto_off_help">Když nejsou po dobu časového limitu vypnutí připojena žádná zařízení: %s</string>
  <string name="wifi_hotspot_timeout">Časový limit vypnutí</string>
  <string name="wifi_hotspot_timeout_help">Nastavte dobu čekání bez připojených zařízení před automatickým vypnutím.&lt;br&gt;&lt;br&gt;Výchozí: %s</string>
