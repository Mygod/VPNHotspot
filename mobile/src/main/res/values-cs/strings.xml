  <string name="wifi_hotspot_ap_band_title">Pásmo př. bodu</string>
  <string name="wifi_hotspot_ap_channel_band_title">Kanál/pásmo AP</string>
  <string name="wifi_hotspot_ap_channel_band_help">Nepodporované pásmo/kanál může způsobit selhání spuštění hotspotu.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Souběžný kanál/pásmo AP</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">Přidá druhou instanci AP, když je podporována souběžnost bridged AP. Nepodporované kombinace pásma/kanálu mohou selhat při spuštění hotspotu.</string>
  <string name="wifi_band_optimization">Povolit optimalizaci pásma</string>
  <string name="wifi_band_optimization_help">Umožní Androidu optimalizovat nastavení pásem, například přidat pásmo 2.4 GHz kvůli souběhu nebo omezením kódu země.</string>
  <string name="wifi_ap_choose_disabled">Vypnuto</string>
  <string name="wifi_ap_choose_G">Pásmo %s GHz</string>
  <string name="wifi_hotspot_acs_channel_2g">Povolené kanály ACS 2.4 GHz</string>
  <string name="wifi_hotspot_acs_channel_5g">Povolené kanály ACS 5 GHz</string>
  <string name="wifi_hotspot_acs_channel_6g">Povolené kanály ACS 6 GHz</string>
  <string name="wifi_hotspot_acs_channel_help">Čísla kanálů povolená pro Automatic Channel Selection v tomto pásmu. Zadejte kanály nebo rozsahy oddělené čárkami, například &lt;tt&gt;1,6,11&lt;/tt&gt; nebo &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Ponechte prázdné pro povolení všech kanálů v pásmu. Vyžaduje podporu ACS offload; jinak Android toto nastavení ignoruje.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Maximální šířka kanálu</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Omezí šířku kanálu Soft AP. Auto umožní Androidu použít nejvyšší šířku dosažitelnou na zařízení.</string>
  <string name="wifi_channel_width_auto">Automaticky</string>
  <string name="wifi_channel_width_invalid">Neplatné</string>
  <string name="wifi_hotspot_access_control_title">Řízení přístupu</string>
  <string name="wifi_hotspot_ap_advanced_title">Rozšířené možnosti</string>
  <string name="wifi_advanced_mac_address_title">Adresa MAC</string>
  <string name="wifi_mac_address_persistent_randomization">Trvalá randomizace: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Netrvalá randomizace</string>
  <string name="wifi_mac_address_help">Nastavte BSSID a randomizaci MAC pro AP. Android odmítá BSSID se samými nulami, multicast a broadcast. Výslovný BSSID se použije jen při vypnuté randomizaci MAC.</string>
  <string name="wifi_p2p_mac_address_help">Nastavte adresu zařízení P2P používanou opakovačem. Nechte prázdné, aby adresu vybral Android.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Trvale randomizovaná MAC adresa</string>
  <string name="wifi_hidden_network">Skrytá síť</string>
  <string name="wifi_hidden_network_help">Nevysílat SSID</string>
  <string name="wifi_max_clients">Maximální počet klientů</string>
  <string name="wifi_max_clients_help">Maximální počet klientů, kteří se mohou přidružit k AP. Prázdná hodnota nechá Android použít limit zařízení nebo operátora; klienti nad limit budou odmítnuti.</string>
  <string name="wifi_blocked_list">Seznam blokovaných klientů</string>
  <string name="wifi_blocked_list_help">MAC adresy, které se nemohou přidružit k Soft AP. Vyžaduje podporu vynuceného odpojení klienta; jinak se hotspot nemusí spustit s chybou nepodporované konfigurace.</string>
  <string name="wifi_client_user_control">Uživatelské řízení přidružení klientů</string>
  <string name="wifi_client_user_control_help">Vypnuto: každý klient mimo blokovaný seznam se může připojit se správnými údaji, dokud se hotspot nezaplní; seznam povolených se ignoruje. Zapnuto: Android používá seznam povolených a blokovaných k přijetí, odmítnutí nebo vyžádání schválení. Vyžaduje vynucené odpojení klienta.</string>
  <string name="wifi_allowed_list">Seznam povolených klientů</string>
  <string name="wifi_client_lists_overlap_error">MAC adresa je v obou seznamech klientů</string>
  <string name="wifi_mac_randomization_none">Bez randomizace</string>
  <string name="wifi_mac_randomization_none_help">Použít tovární nebo výslovně nastavenou MAC adresu AP.</string>
  <string name="wifi_mac_randomization_persistent">Trvalá randomizace</string>
  <string name="wifi_mac_randomization_persistent_help">Vygeneruje náhodnou MAC adresu AP, která je uchována pro každé SSID, dokud SSID zůstává stejné.</string>
  <string name="wifi_mac_randomization_non_persistent">Netrvalá randomizace</string>
  <string name="wifi_mac_randomization_non_persistent_help">Vygeneruje náhodnou MAC adresu AP při každém opětovném zapnutí AP.</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown">Oportunní vypnutí v přemostěném režimu</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown_help">V režimu bridged AP může Android vypnout nečinnou instanci AP po časovém limitu mostu: %s</string>
  <string name="wifi_hotspot_timeout_bridged">Časový limit nečinnosti pro přemostěnou instanci</string>
  <string name="wifi_hotspot_timeout_bridged_help">Nastavte dobu, po kterou nečinná bridged AP instance čeká před oportunistickým vypnutím. Pokud jsou obě instance nečinné, Android vypne instanci s vyšší frekvencí. Celkový časový limit hotspotu stále platí samostatně.&lt;br&gt;&lt;br&gt;Výchozí: %s</string>
