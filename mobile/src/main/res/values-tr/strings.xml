  <string name="wifi_mac_randomization_none_help">Fabrika veya açıkça yapılandırılmış AP MAC adresini kullan.</string>
  <string name="wifi_mac_randomization_persistent">Kalıcı rastgeleleştirme</string>
  <string name="wifi_mac_randomization_persistent_help">SSID aynı kaldığı sürece SSID başına saklanan rastgele bir AP MAC adresi oluşturur.</string>
  <string name="wifi_mac_randomization_non_persistent">Kalıcı olmayan rastgeleleştirme</string>
  <string name="wifi_mac_randomization_non_persistent_help">AP yeniden etkinleştirildiğinde her seferinde rastgele bir AP MAC adresi oluşturur.</string>
