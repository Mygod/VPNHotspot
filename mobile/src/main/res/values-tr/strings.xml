  <string name="wifi_mac_address_non_persistent_randomization">Kalıcı olmayan rastgeleleştirme</string>
  <string name="wifi_mac_address_help">AP için BSSID ve MAC rastgeleleştirmesini yapılandırın. Android tümü sıfır, multicast ve broadcast BSSID\'leri reddeder. Açık BSSID yalnızca MAC rastgeleleştirmesi kapalıyken kullanılır.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Kalıcı rastgele MAC adresi</string>
