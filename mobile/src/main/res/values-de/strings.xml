  <string name="wifi_password_help">Vorinstallierter Schlüssel für persönliche WPA2/WPA3-Sicherheit. Passphrasen für WPA2-PSK- und WPA3-SAE-Übergang müssen 8–63 Zeichen lang sein.</string>
  <string name="wifi_hotspot_auto_off">Hotspot automatisch deaktivieren</string>
  <string name="wifi_hotspot_auto_off_help">Wenn für die Abschaltzeit keine Geräte verbunden sind: %s</string>
  <string name="wifi_hotspot_timeout">Ausschalt-Timeout</string>
  <string name="wifi_hotspot_timeout_help">Legen Sie fest, wie lange ohne verbundene Geräte bis zum automatischen Abschalten gewartet wird.&lt;br&gt;&lt;br&gt;Standard: %s</string>
  <string name="wifi_hotspot_timeout_default">Standard (%s)</string>
  <string name="wifi_hotspot_ap_band_title">Band für Zugangspunkt</string>
  <string name="wifi_hotspot_ap_channel_band_title">AP-Kanal/Band</string>
  <string name="wifi_hotspot_ap_channel_band_help">Ein nicht unterstütztes Band oder ein nicht unterstützter Kanal kann den Hotspot-Start fehlschlagen lassen.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Gleichzeitiger AP-Kanal/Band</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">Fügt eine zweite AP-Instanz hinzu, wenn Bridged-AP-Parallelbetrieb unterstützt wird. Nicht unterstützte Band/Kanal-Kombinationen können beim Starten des Hotspots fehlschlagen.</string>
  <string name="wifi_band_optimization">Bandoptimierung aktivieren</string>
  <string name="wifi_band_optimization_help">Erlaubt Android, Bandeinstellungen zu optimieren, etwa das 2.4-GHz-Band wegen Koexistenz oder Länderbeschränkungen hinzuzufügen.</string>
  <string name="wifi_ap_choose_disabled">Deaktiviert</string>
  <string name="wifi_ap_choose_G">%s-GHz-Band</string>
  <string name="wifi_hotspot_acs_channel_2g">Zulässige 2.4-GHz-ACS-Kanäle</string>
  <string name="wifi_hotspot_acs_channel_5g">Zulässige 5-GHz-ACS-Kanäle</string>
  <string name="wifi_hotspot_acs_channel_6g">Zulässige 6-GHz-ACS-Kanäle</string>
  <string name="wifi_hotspot_acs_channel_help">Kanalnummern, die für die automatische Kanalauswahl in diesem Band erlaubt sind. Gib durch Kommas getrennte Kanäle oder Bereiche ein, z. B. &lt;tt&gt;1,6,11&lt;/tt&gt; oder &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Leer lassen, um alle Kanäle im Band zuzulassen. Erfordert ACS-Offload-Unterstützung, sonst ignoriert Android diese Einstellung.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Maximale Kanalbandbreite</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Begrenzt die Kanalbandbreite des Soft AP. Auto lässt Android die auf dem Gerät erreichbare maximale Bandbreite verwenden.</string>
  <string name="wifi_channel_width_auto">Autom.</string>
  <string name="wifi_channel_width_invalid">Ungültig</string>
  <string name="wifi_hotspot_access_control_title">Zugriffssteuerung</string>
  <string name="wifi_hotspot_ap_advanced_title">Erweiterte Optionen</string>
  <string name="wifi_advanced_mac_address_title">MAC-Adresse</string>
  <string name="wifi_mac_address_persistent_randomization">Dauerhafte Randomisierung: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Nicht dauerhafte Randomisierung</string>
  <string name="wifi_mac_address_help">Konfigurieren Sie BSSID und MAC-Randomisierung für den AP. Android lehnt BSSIDs nur aus Nullen, Multicast- und Broadcast-BSSIDs ab. Eine explizite BSSID wird nur verwendet, wenn MAC-Randomisierung deaktiviert ist.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Persistente zufällige MAC-Adresse</string>
  <string name="wifi_hidden_network">Verborgenes Netzwerk</string>
  <string name="wifi_hidden_network_help">SSID nicht senden</string>
  <string name="wifi_max_clients">Maximale Anzahl von Clients</string>
  <string name="wifi_max_clients_help">Maximale Anzahl von Clients, die sich mit dem AP verbinden dürfen. Leer bedeutet, dass Android das Geräte- oder Betreiberlimit verwendet; Clients über dem Limit werden abgewiesen.</string>
  <string name="wifi_blocked_list">Liste blockierter Clients</string>
  <string name="wifi_blocked_list_help">MAC-Adressen, die sich nicht mit dem Soft AP verbinden dürfen. Erfordert Unterstützung für erzwungene Client-Trennung; sonst kann der Hotspot mit einem Fehler wegen nicht unterstützter Konfiguration nicht starten.</string>
  <string name="wifi_client_user_control">Benutzersteuerung der Client-Zuordnung</string>
  <string name="wifi_client_user_control_help">Aus: Jeder Client außerhalb der Sperrliste kann sich mit den richtigen Daten verbinden, bis der Hotspot voll ist; die Zulassungsliste wird ignoriert. Ein: Android verwendet Zulassungs- und Sperrlisten, um Clients anzunehmen, abzulehnen oder Genehmigung anzufordern. Erfordert erzwungene Client-Trennung.</string>
  <string name="wifi_allowed_list">Liste zugelassener Clients</string>
  <string name="wifi_client_lists_overlap_error">Eine MAC-Adresse ist in beiden Clientlisten vorhanden</string>
  <string name="wifi_mac_randomization_none">Keine Randomisierung</string>
  <string name="wifi_mac_randomization_none_help">Die werkseitige oder ausdrücklich konfigurierte AP-MAC-Adresse verwenden.</string>
  <string name="wifi_mac_randomization_persistent">Dauerhafte Randomisierung</string>
  <string name="wifi_mac_randomization_persistent_help">Eine zufällige AP-MAC-Adresse erzeugen, die pro SSID beibehalten wird, solange die SSID gleich bleibt.</string>
  <string name="wifi_mac_randomization_non_persistent">Nicht dauerhafte Randomisierung</string>
  <string name="wifi_mac_randomization_non_persistent_help">Bei jeder erneuten Aktivierung des AP eine zufällige AP-MAC-Adresse erzeugen.</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown">Opportunistisches Herunterfahren im Bridge-Modus</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown_help">Im Bridged-AP-Modus kann Android eine inaktive AP-Instanz nach dem Bridged-Timeout abschalten: %s</string>
  <string name="wifi_hotspot_timeout_bridged">Inaktivitäts-Timeout für eine Bridge-Instanz</string>
  <string name="wifi_hotspot_timeout_bridged_help">Konfiguriere, wie lange eine inaktive Bridged-AP-Instanz vor der opportunistischen Abschaltung wartet. Wenn beide Instanzen inaktiv sind, schaltet Android die höherfrequente Instanz ab. Das gesamte Hotspot-Timeout gilt weiterhin separat.&lt;br&gt;&lt;br&gt;Standard: %s</string>
