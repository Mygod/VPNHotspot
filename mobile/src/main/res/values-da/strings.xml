  <string name="settings_service_upstream_help">Regex for hoved-opstrømsgrænsefladen, der bruges til at omdirigere nedstrømstrafik. VPN Hotspot selv skal have lov til at bruge den VPN for at fungere. Brug &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; eller en anden ugyldig regex for at undertrykke deling gennem VPN.</string>
  <string name="settings_upstream_fallback_help">Reserve-opstrøm bruges, når en VPN efterlader nogle ruter på standardnetværket. Brug &lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; eller en anden ugyldig regex for at forbyde reserve.</string>
  <string name="settings_service_masquerade_none_summary">Omskriv ikke nedstrøms kildeadresser eller porte. Dette kan fungere bedre med dummy-VPN’er som annonceblokkere, men bør ikke bruges med rigtige VPN’er.</string>
  <string name="settings_service_masquerade_simple_summary">Omskriv nedstrøms kildeadresser og porte i app-ejede routingregler.</string>
  <string name="settings_service_masquerade_netd_summary">Bed Android &lt;tt&gt;netd&lt;/tt&gt; om at håndtere masquerade. Android kan tilføje platform extras som &lt;tt&gt;FTP&lt;/tt&gt;-håndtering og tethering-tællere, men det passer dårligt, når tetheringaktivitet skal skjules for operatøren.</string>
  <string name="settings_service_ipv6_mode_system_summary">Overlad IPv6-håndtering til platformens routingopsætning.</string>
  <string name="settings_service_ipv6_mode_block_summary">Forhindr IPv6-lækager på nedstrømsgrænseflader.</string>
  <string name="settings_service_ipv6_mode_nat_summary">Tildeler en deterministisk app-ejet ULA &lt;tt&gt;/64&lt;/tt&gt; og proxyer nedstrøms IPv6 &lt;tt&gt;TCP&lt;/tt&gt;/&lt;tt&gt;UDP&lt;/tt&gt; plus best-effort &lt;tt&gt;ICMPv6&lt;/tt&gt; gennem root-daemonen. Dette er brugerrumsarbejde, ikke fuld pakke-NAT, og videresender ikke andre IPv6 next-header-protokoller.</string>
  <string name="settings_service_auto_start">Start tjenester automatisk</string>
  <string name="settings_service_auto_start_summary">Gendan tjenester, hvis de kørte før enhedsgenstart eller appopdatering.</string>
  <string name="settings_service_repeater_safe_mode">Sikker tilstand for repeater</string>
  <string name="settings_service_repeater_safe_mode_summary">Foretager ingen ændringer i systemkonfigurationen, men virker muligvis ikke med korte netværksnavne. Usikker tilstand virker muligvis ikke på din enhed og kan midlertidigt gøre den ubrugelig på en måde, der kan gendannes.</string>
  <string name="settings_service_repeater_safe_mode_warning">Korte netværksnavne kan kræve, at sikker tilstand slås fra.</string>
  <string name="settings_service_temp_hotspot_use_system">Brug systemkonfiguration til midlertidigt hotspot</string>
  <string name="settings_service_temp_hotspot_use_system_summary">Vil være i konflikt med andre apps, der bruger lokalt hotspot. Bruger også flere ressourcer i baggrunden, medmindre den er installeret som systemapp.</string>
  <string name="settings_service_temp_hotspot_use_system_summary_api30">Vil være i konflikt med andre apps, der bruger lokalt hotspot. Bruger også flere ressourcer i baggrunden, medmindre den er installeret som systemapp. Fungerer sandsynligvis på Android 12 eller nyere.</string>
  <string name="settings_service_wifi_lock">Hold Wi‑Fi aktiv</string>
  <string name="settings_service_wifi_lock_none">Systemstandard</string>
  <string name="settings_service_wifi_lock_high_perf_v29">Deaktiver strømbesparelse</string>
  <string name="settings_service_wifi_lock_low_latency">Lav latenstilstand</string>
  <string name="settings_service_wifi_lock_none_summary">Brug systemets standardadfærd for Wi‑Fi-strøm for at spare batteri.</string>
  <string name="settings_service_wifi_lock_high_perf_v29_summary">Reducerer pakkeforsinkelse i tilfælde som taleopkald efter skærmen slukkes. Kræver hardwareunderstøttelse. På Android 14 og nyere erstattes denne forældede tilstand af lav latenstilstand.</string>
  <string name="settings_service_wifi_lock_low_latency_summary">Optimerer latenstidsfølsom brug som spil eller virtuel virkelighed. Kan reducere batteritid, gennemløb, Wi‑Fi-scanningsfrekvens, roamingkvalitet og placeringsnøjagtighed. Kræver hardwareunderstøttelse og at denne app kører i forgrunden med skærmen tændt.</string>
