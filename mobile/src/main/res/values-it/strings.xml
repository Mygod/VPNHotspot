  <string name="wifi_mac_address_persistent_randomization">Randomizzazione persistente: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Randomizzazione non persistente</string>
  <string name="wifi_mac_address_help">Configura BSSID e randomizzazione MAC per l’AP. Android rifiuta BSSID tutti zero, multicast e broadcast. Un BSSID esplicito viene usato solo quando la randomizzazione MAC è disattivata.</string>
  <string name="wifi_p2p_mac_address_help">Configura l’indirizzo del dispositivo P2P usato dal ripetitore. Lascia vuoto per far scegliere l’indirizzo ad Android.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Indirizzo MAC casuale persistente</string>
  <string name="wifi_hidden_network">Rete nascosta</string>
  <string name="wifi_hidden_network_help">Non trasmettere l’SSID</string>
  <string name="wifi_max_clients">Numero massimo di client</string>
  <string name="wifi_max_clients_help">Numero massimo di client che possono associarsi all’AP. Se vuoto, Android usa il limite del dispositivo o dell’operatore; i client oltre il limite vengono rifiutati.</string>
  <string name="wifi_blocked_list">Elenco client bloccati</string>
  <string name="wifi_blocked_list_help">Indirizzi MAC che non possono associarsi al Soft AP. Richiede il supporto alla disconnessione forzata dei client; altrimenti l’hotspot può non avviarsi con un errore di configurazione non supportata.</string>
  <string name="wifi_client_user_control">Controllo utente dell’associazione client</string>
  <string name="wifi_client_user_control_help">Disattivato: qualsiasi client fuori dall’elenco bloccati può connettersi con le credenziali corrette finché l’hotspot non è pieno; l’elenco consentiti viene ignorato. Attivato: Android usa gli elenchi consentiti e bloccati per accettare, rifiutare o chiedere approvazione. Richiede la disconnessione forzata dei client.</string>
  <string name="wifi_allowed_list">Elenco client consentiti</string>
  <string name="wifi_client_lists_overlap_error">Un indirizzo MAC è presente in entrambi gli elenchi client</string>
  <string name="wifi_mac_randomization_none">Nessuna randomizzazione</string>
  <string name="wifi_mac_randomization_none_help">Usa l’indirizzo MAC AP di fabbrica o configurato esplicitamente.</string>
  <string name="wifi_mac_randomization_persistent">Randomizzazione persistente</string>
  <string name="wifi_mac_randomization_persistent_help">Genera un indirizzo MAC AP casuale conservato per SSID finché l’SSID resta invariato.</string>
  <string name="wifi_mac_randomization_non_persistent">Randomizzazione non persistente</string>
  <string name="wifi_mac_randomization_non_persistent_help">Genera un indirizzo MAC AP casuale ogni volta che l’AP viene riattivato.</string>
