  <string name="wifi_mac_randomization_none_help">Folosește adresa MAC AP din fabrică sau configurată explicit.</string>
  <string name="wifi_mac_randomization_persistent">Randomizare persistentă</string>
  <string name="wifi_mac_randomization_persistent_help">Generează o adresă MAC AP aleatorie păstrată per SSID cât timp SSID-ul rămâne același.</string>
  <string name="wifi_mac_randomization_non_persistent">Randomizare nepersistentă</string>
  <string name="wifi_mac_randomization_non_persistent_help">Generează o adresă MAC AP aleatorie de fiecare dată când AP este reactivat.</string>
