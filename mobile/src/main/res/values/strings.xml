    <string name="wifi_hotspot_ap_band_title">AP Band</string>
    <string name="wifi_hotspot_ap_channel_band_title">AP channel/band</string>
    <string name="wifi_hotspot_ap_channel_band_help">Choose the band and channel. Channel &lt;tt&gt;0&lt;/tt&gt; lets Android auto-select a valid channel for the selected band. Valid channels depend on country and device capabilities.</string>
    <string name="wifi_hotspot_concurrent_ap_channel_band_title">Concurrent AP channel/band</string>
    <string name="wifi_hotspot_concurrent_ap_channel_band_help">Adds a second AP instance when bridged AP concurrency is supported. Channel &lt;tt&gt;0&lt;/tt&gt; lets Android auto-select. Unsupported band/channel combinations can fail when the hotspot starts.</string>
    <string name="wifi_band_optimization">Enable band optimization</string>
    <string name="wifi_band_optimization_help">Lets Android optimize band settings, such as appending the 2.4 GHz band for coexistence or country-code restrictions.</string>
    <string name="wifi_ap_choose_disabled">Disabled</string>
    <string name="wifi_ap_choose_G">%s GHz Band</string>
    <string name="wifi_hotspot_acs_channel_2g">Allowed 2.4 GHz ACS channels</string>
    <string name="wifi_hotspot_acs_channel_5g">Allowed 5 GHz ACS channels</string>
    <string name="wifi_hotspot_acs_channel_6g">Allowed 6 GHz ACS channels</string>
    <string name="wifi_hotspot_acs_channel_help">Channel numbers allowed for Automatic Channel Selection in this band. Leave empty to allow all channels in the band. Requires ACS offload support; otherwise Android ignores this setting.</string>
    <string name="wifi_hotspot_max_channel_bandwidth">Maximum channel bandwidth</string>
    <string name="wifi_hotspot_max_channel_bandwidth_help">Caps Soft AP channel bandwidth. Auto lets Android use the maximum bandwidth achievable on the device.</string>
    <string name="wifi_hotspot_access_control_title">Access Control</string>
    <string name="wifi_hotspot_ap_advanced_title">Advanced AP Options</string>
    <string name="wifi_advanced_mac_address_title">MAC address</string>
    <string name="wifi_advanced_mac_address_help">BSSID for the AP. Android rejects all-zero, multicast, and broadcast MAC addresses. When setting a BSSID, MAC randomization must be disabled.</string>
    <string name="wifi_advanced_mac_address_persistent_randomized">Persistent Randomized MAC address</string>
    <string name="wifi_advanced_mac_address_persistent_randomized_help">Persistent randomized MAC address generated by the framework for this configuration.</string>
    <string name="wifi_hidden_network">Hidden network</string>
    <string name="wifi_hidden_network_help">Do not broadcast the SSID.</string>
    <string name="wifi_max_clients">Maximum number of clients</string>
    <string name="wifi_max_clients_help">Maximum number of clients that can associate with the AP. &lt;tt&gt;0&lt;/tt&gt; lets Android use the device or carrier limit; clients above the limit are rejected.</string>
    <string name="wifi_blocked_list">Blocked list of clients</string>
    <string name="wifi_blocked_list_help">MAC addresses that cannot associate with the Soft AP. Requires client force-disconnect support; otherwise the hotspot can fail to start with an unsupported-configuration error.</string>
    <string name="wifi_client_user_control">Control which client can use hotspot</string>
    <string name="wifi_client_user_control_help">When off, any client not in the blocked list can connect until capacity is reached. When on, Android uses the allowed and blocked lists to accept, reject, or require approval for clients.</string>
    <string name="wifi_allowed_list">Allowed list of clients</string>
    <string name="wifi_allowed_list_help">MAC addresses that are auto-accepted when client control is enabled. Other clients not on either list are rejected and reported through the Soft AP callback.</string>
    <string name="wifi_mac_randomization">Use randomized MAC</string>
    <string name="wifi_mac_randomization_help">Controls BSSID randomization. Randomization applies only when no explicit BSSID is set and requires MAC address customization support.</string>
    <string name="wifi_mac_randomization_none">None</string>
    <string name="wifi_mac_randomization_none_help">Use the factory or explicitly configured AP MAC address.</string>
    <string name="wifi_mac_randomization_persistent">Persistent</string>
    <string name="wifi_mac_randomization_persistent_help">Generate a randomized AP MAC address that is persisted per SSID while the SSID stays the same.</string>
    <string name="wifi_mac_randomization_non_persistent">Non-persistent</string>
    <string name="wifi_mac_randomization_non_persistent_help">Generate a randomized AP MAC address each time the AP is re-enabled.</string>
    <string name="wifi_bridged_mode_opportunistic_shutdown">Bridged mode opportunistic shutdown</string>
    <string name="wifi_bridged_mode_opportunistic_shutdown_help">In bridged AP mode, Android can shut down an idle AP instance after the bridged timeout: %s.</string>
    <string name="wifi_hotspot_timeout_bridged">Inactive timeout for a bridged instance</string>
    <string name="wifi_hotspot_timeout_bridged_help">Configure the time an idle bridged AP instance waits before opportunistic shutdown. If both instances are idle, Android shuts down the higher-frequency instance. The overall hotspot timeout still applies separately.&lt;br&gt;&lt;br&gt;Default: %s.</string>
    <string name="wifi_ieee_80211ax">Enable Wi\u2011Fi 6</string>
    <string name="wifi_ieee_80211ax_help">Enable 802.11ax for Soft AP when the device supports it.</string>
    <string name="wifi_ieee_80211be">Enable Wi\u2011Fi 7</string>
    <string name="wifi_ieee_80211be_help">Enable 802.11be for Soft AP when the device supports it.</string>
    <string name="wifi_user_config">User supplied configuration</string>
    <string name="wifi_user_config_help">Marks whether this Soft AP configuration was supplied by the user.</string>
    <string name="wifi_vendor_elements">Vendor elements</string>
    <string name="wifi_vendor_elements_help">Vendor-specific information elements transmitted in Soft AP beacons and probe responses. Android accepts only vendor-specific IE ID &lt;tt&gt;0xDD&lt;/tt&gt; and rejects duplicate elements.</string>
    <string name="wifi_client_isolation">Client isolation</string>
    <string name="wifi_client_isolation_help">Disallow a connected Soft AP client from communicating with other connected clients.</string>
