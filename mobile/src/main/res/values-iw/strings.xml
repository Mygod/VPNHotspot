  <string name="settings_service_wifi_lock_low_latency">מצב השהיה נמוכה</string>
  <string name="settings_service_wifi_lock_none_summary">שימוש בהתנהגות ברירת המחדל של צריכת Wi‑Fi במערכת כדי לחסוך בסוללה.</string>
  <string name="settings_service_wifi_lock_high_perf_v29_summary">מפחית השהיית חבילות במקרים כמו שיחות קוליות לאחר כיבוי המסך. דורש תמיכת חומרה. ב-Android 14 ומעלה, מצב מיושן זה מוחלף במצב השהיה נמוכה.</string>
  <string name="settings_service_wifi_lock_low_latency_summary">ממטב שימושים הרגישים להשהיה, כגון משחקים או מציאות מדומה. עשוי להפחית את חיי הסוללה, התפוקה, תדירות סריקת Wi‑Fi, איכות הנדידה ודיוק המיקום. דורש תמיכת חומרה והפעלה של האפליקציה בחזית כשהמסך דולק.</string>
