  <string name="settings_service_upstream_help">regex של ממשק upstream הראשי המשמש לניתוב מחדש של תעבורה downstream. VPN Hotspot עצמו חייב להיות מורשה להשתמש ב-VPN הזה כדי לעבוד. השתמשו ב-&lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; או regex לא חוקי אחר כדי לדכא שיתוף דרך VPN.</string>
  <string name="settings_upstream_fallback_help">upstream גיבוי משמש כאשר VPN משאיר חלק מהנתיבים ברשת ברירת המחדל. השתמשו ב-&lt;tt&gt;none&lt;/tt&gt;, &lt;tt&gt;a^&lt;/tt&gt; או regex לא חוקי אחר כדי לאסור גיבוי.</string>
  <string name="settings_service_masquerade_none_summary">לא לשכתב כתובות מקור או יציאות של התעבורה היורדת. מצב זה יכול לעבוד טוב יותר עם VPN מדומה כגון חוסמי פרסומות או socksifier, אך אין להשתמש בו עם VPN אמיתי.</string>
  <string name="settings_service_masquerade_simple_summary">שכתוב כתובות המקור והיציאות של התעבורה היורדת בכללי הניתוב שבבעלות האפליקציה.</string>
  <string name="settings_service_masquerade_netd_summary">לבקש מ-&lt;tt&gt;netd&lt;/tt&gt; של Android לטפל ב-masquerade. Android עשויה להוסיף תוספות פלטפורמה כגון טיפול ב-&lt;tt&gt;FTP&lt;/tt&gt; ומוני tethering, אך זו התאמה גרועה כאשר רוצים להסתיר פעילות tethering מהמפעיל.</string>
  <string name="settings_service_ipv6_mode_system_summary">השאר את הטיפול ב-IPv6 להגדרות הניתוב של הפלטפורמה.</string>
  <string name="settings_service_ipv6_mode_block_summary">מונע דליפות IPv6 בממשקים downstream.</string>
  <string name="settings_service_ipv6_mode_nat_summary">מקצה ULA &lt;tt&gt;/64&lt;/tt&gt; דטרמיניסטי בבעלות האפליקציה ומבצע proxy ל-IPv6 downstream ‏&lt;tt&gt;TCP&lt;/tt&gt;/&lt;tt&gt;UDP&lt;/tt&gt; וגם &lt;tt&gt;ICMPv6&lt;/tt&gt; best-effort דרך root daemon. זו עבודה במרחב משתמש, לא packet NAT מלא, והיא לא מעבירה פרוטוקולי IPv6 next-header אחרים.</string>
  <string name="settings_service_auto_start">הפעלת שירותים אוטומטית</string>
  <string name="settings_service_auto_start_summary">שחזור שירותים אם הם פעלו לפני הפעלה מחדש של המכשיר או עדכון האפליקציה.</string>
  <string name="settings_service_repeater_safe_mode">מצב בטוח של המשחזר</string>
  <string name="settings_service_repeater_safe_mode_summary">לא מבצע שינויים בתצורת המערכת, אך ייתכן שלא יעבוד עם שמות רשת קצרים. מצב לא בטוח עשוי לא לעבוד במכשיר שלך ועלול להפוך אותו זמנית ללא שמיש באופן שניתן לשחזור.</string>
  <string name="settings_service_repeater_safe_mode_warning">שמות רשת קצרים עשויים לדרוש כיבוי של מצב בטוח.</string>
  <string name="settings_service_temp_hotspot_use_system">שימוש בתצורת המערכת עבור hotspot זמני</string>
  <string name="settings_service_temp_hotspot_use_system_summary">יתנגש עם אפליקציות אחרות המשתמשות ב-hotspot מקומי בלבד. גם משתמש ביותר משאבים ברקע אלא אם הוא מותקן כאפליקציית מערכת.</string>
  <string name="settings_service_temp_hotspot_use_system_summary_api30">יתנגש עם אפליקציות אחרות המשתמשות ב-hotspot מקומי בלבד. גם משתמש ביותר משאבים ברקע אלא אם הוא מותקן כאפליקציית מערכת. סביר שיעבוד ב-Android 12 ומעלה.</string>
  <string name="settings_service_wifi_lock">השארת Wi‑Fi פעיל</string>
