  <string name="wifi_hotspot_concurrent_ap_channel_band_title">ערוץ/תחום AP מקביל</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">מוסיף מופע AP שני כאשר נתמכת בו-זמניות של bridged AP. שילובי תחום/ערוץ שאינם נתמכים עלולים להיכשל בעת הפעלת ה-hotspot.</string>
  <string name="wifi_band_optimization">הפעלת מיטוב תחום</string>
  <string name="wifi_band_optimization_help">מאפשר ל-Android למטב הגדרות תחום, למשל להוסיף את תחום 2.4 GHz לצורך דו-קיום או מגבלות קוד מדינה.</string>
