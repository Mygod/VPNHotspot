  <string name="wifi_hotspot_ap_band_title">Banda del PA</string>
  <string name="wifi_hotspot_ap_channel_band_title">Canal/banda de l’AP</string>
  <string name="wifi_hotspot_ap_channel_band_help">Una banda o un canal no compatible pot fer que el punt d’accés no s’iniciï.</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_title">Canal/banda de l’AP concurrent</string>
  <string name="wifi_hotspot_concurrent_ap_channel_band_help">Afegeix una segona instància AP quan s’admet la concurrència AP en pont. Les combinacions de banda/canal no admeses poden fallar quan s’inicia el punt d’accés.</string>
  <string name="wifi_band_optimization">Activa l’optimització de banda</string>
  <string name="wifi_band_optimization_help">Permet que Android optimitzi la configuració de banda, com afegir la banda de 2.4 GHz per coexistència o restriccions de codi de país.</string>
  <string name="wifi_ap_choose_disabled">Desactivat</string>
  <string name="wifi_ap_choose_G">Banda de %s GHz</string>
  <string name="wifi_hotspot_acs_channel_2g">Canals ACS de 2.4 GHz permesos</string>
  <string name="wifi_hotspot_acs_channel_5g">Canals ACS de 5 GHz permesos</string>
  <string name="wifi_hotspot_acs_channel_6g">Canals ACS de 6 GHz permesos</string>
  <string name="wifi_hotspot_acs_channel_help">Números de canal permesos per a la selecció automàtica de canal en aquesta banda. Introdueix canals o intervals separats per comes, com &lt;tt&gt;1,6,11&lt;/tt&gt; o &lt;tt&gt;36-48,149-161&lt;/tt&gt;. Deixa-ho buit per permetre tots els canals de la banda. Requereix compatibilitat amb ACS offload; altrament Android ignora aquest ajust.</string>
  <string name="wifi_hotspot_max_channel_bandwidth">Amplada màxima del canal</string>
  <string name="wifi_hotspot_max_channel_bandwidth_help">Limita l’amplada del canal del Soft AP. Auto permet que Android utilitzi l’amplada màxima possible al dispositiu.</string>
  <string name="wifi_channel_width_auto">Automàtic</string>
  <string name="wifi_channel_width_invalid">No vàlid</string>
  <string name="wifi_hotspot_access_control_title">Control d’accés</string>
  <string name="wifi_hotspot_ap_advanced_title">Opcions avançades</string>
  <string name="wifi_advanced_mac_address_title">Adreça MAC</string>
  <string name="wifi_mac_address_persistent_randomization">Aleatorització persistent: %s</string>
  <string name="wifi_mac_address_non_persistent_randomization">Aleatorització no persistent</string>
  <string name="wifi_mac_address_help">Configureu el BSSID i l’aleatorització de MAC per a l’AP. Android rebutja BSSID de tot zeros, multicast i broadcast. Un BSSID explícit només s’utilitza quan l’aleatorització de MAC està desactivada.</string>
  <string name="wifi_advanced_mac_address_persistent_randomized">Adreça MAC aleatòria persistent</string>
  <string name="wifi_hidden_network">Xarxa amagada</string>
  <string name="wifi_hidden_network_help">No difondre l’SSID</string>
  <string name="wifi_max_clients">Nombre màxim de clients</string>
  <string name="wifi_max_clients_help">Nombre màxim de clients que es poden associar amb l’AP. Si es deixa buit, Android utilitza el límit del dispositiu o de l’operador; els clients que superen el límit es rebutgen.</string>
  <string name="wifi_blocked_list">Llista de clients bloquejats</string>
  <string name="wifi_blocked_list_help">Adreces MAC que no es poden associar amb el Soft AP. Requereix compatibilitat amb la desconnexió forçada de clients; altrament, el punt d’accés pot no iniciar-se amb un error de configuració no compatible.</string>
  <string name="wifi_client_user_control">Control d’usuari de l’associació de clients</string>
  <string name="wifi_client_user_control_help">Desactivat: qualsevol client fora de la llista bloquejada pot connectar-se amb les credencials correctes fins que el punt d’accés s’ompli; la llista permesa s’ignora. Activat: Android utilitza les llistes permesa i bloquejada per acceptar, rebutjar o demanar aprovació. Requereix desconnexió forçada de clients.</string>
  <string name="wifi_allowed_list">Llista de clients permesos</string>
  <string name="wifi_client_lists_overlap_error">Hi ha una adreça MAC a totes dues llistes de clients</string>
  <string name="wifi_mac_randomization_none">Sense aleatorització</string>
  <string name="wifi_mac_randomization_none_help">Fes servir l’adreça MAC de l’AP de fàbrica o configurada explícitament.</string>
  <string name="wifi_mac_randomization_persistent">Aleatorització persistent</string>
  <string name="wifi_mac_randomization_persistent_help">Genera una adreça MAC de l’AP aleatòria que es conserva per SSID mentre l’SSID no canviï.</string>
  <string name="wifi_mac_randomization_non_persistent">Aleatorització no persistent</string>
  <string name="wifi_mac_randomization_non_persistent_help">Genera una adreça MAC de l’AP aleatòria cada vegada que es torna a activar l’AP.</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown">Apagat oportunista en mode pont</string>
  <string name="wifi_bridged_mode_opportunistic_shutdown_help">En mode AP en pont, Android pot apagar una instància AP inactiva després del temps d’espera en pont: %s</string>
  <string name="wifi_hotspot_timeout_bridged">Temps d\'inactivitat per a una instància pont</string>
  <string name="wifi_hotspot_timeout_bridged_help">Configura el temps que espera una instància AP en pont inactiva abans de l’apagada oportunista. Si totes dues instàncies estan inactives, Android apaga la instància de freqüència més alta. El temps d’espera general del punt d’accés continua aplicant-se per separat.&lt;br&gt;&lt;br&gt;Predeterminat: %s</string>
