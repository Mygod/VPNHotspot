  <string name="wifi_hotspot_timeout">Temps d\'aturada</string>
  <string name="wifi_hotspot_timeout_help">Configureu el temps d’espera sense dispositius connectats abans de l’apagada automàtica.&lt;br&gt;&lt;br&gt;Per defecte: %s</string>
